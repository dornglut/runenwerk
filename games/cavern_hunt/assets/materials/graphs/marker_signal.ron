(
    version: 1,
    id: "marker_signal",
    nodes: [
        (
            id: "world_pos",
            kind: WorldPos,
        ),
        (
            id: "pulse_noise",
            kind: FbmNoise(
                position: "world_pos",
                scale: 0.6,
                octaves: 2,
                lacunarity: 2.0,
                gain: 0.55,
                seed: 133.0,
            ),
        ),
        (
            id: "pulse_bias",
            kind: ConstantScalar(value: 0.75),
        ),
        (
            id: "pulse",
            kind: Clamp01(
                input: "pulse_noise",
            ),
        ),
        (
            id: "pulse_scaled",
            kind: Multiply(
                a: "pulse",
                b: "pulse_bias",
            ),
        ),
        (
            id: "pulse_vec",
            kind: ToVec3(input: "pulse_scaled"),
        ),
        (
            id: "base_tint",
            kind: ConstantVec3(value: (0.18, 0.40, 0.88)),
        ),
        (
            id: "base_color",
            kind: Add(
                a: "base_tint",
                b: "pulse_vec",
            ),
        ),
        (
            id: "roughness",
            kind: ConstantScalar(value: 0.35),
        ),
        (
            id: "metallic",
            kind: ConstantScalar(value: 0.04),
        ),
        (
            id: "ao",
            kind: ConstantScalar(value: 1.0),
        ),
        (
            id: "emissive_tint",
            kind: ConstantVec3(value: (0.25, 0.72, 1.0)),
        ),
        (
            id: "emissive",
            kind: Multiply(
                a: "pulse_vec",
                b: "emissive_tint",
            ),
        ),
    ],
    outputs: (
        base_color: "base_color",
        roughness: "roughness",
        metallic: "metallic",
        normal_perturb: None,
        ao: Some("ao"),
        emissive: Some("emissive"),
    ),
)
