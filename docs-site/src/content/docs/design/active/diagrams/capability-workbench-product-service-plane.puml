@startuml
title Capability Workbench Product And Service Capability Plane

skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Monospaced

package "Capability Cell / Tool Suite" as CellPkg {
  component "Suite declaration\nsurfaces + profiles\nProductCapabilityKey values\nToolServiceKey dependencies" as Suite
}

package "domain/editor/editor_shell" as ShellPkg {
  component "Declaration vocabulary\nstable id validation\nduplicate detection\nstatus/diagnostic DTOs" as ShellContracts
}

package "Workbench Host" as HostPkg {
  component "HostCapabilityPolicy\ncommand/product/resource policy\nservice invocation policy" as HostPolicy
  component "Provider bundle\nprofile/provider composition\nobserved workbench status" as HostComposition
}

package "Owning Domains" as DomainPkg {
  component "Domain source truth\ncommands + validation\nratification + lowering\nproduct descriptors" as DomainTruth
}

package "App / Supervised Service Formation" as FormationPkg {
  component "App-owned product workflow\nruntime adapters\nin-process jobs" as AppFormation
  component "Future supervised service\nmetadata-only in WR-038\nno protocol selected" as FutureService
}

package "Product Graph / Runtime Consumers" as ProductPkg {
  component "Product graph nodes\ncache/provenance/status\nformed product adoption" as ProductGraph
  component "Render/runtime consumers\nformed products only" as Consumers
}

package "Diagnostics" as DiagnosticsPkg {
  component "Denied capability\nmissing service\nproduct failed\nservice unavailable\nlast-good status" as Diagnostics
}

Suite --> ShellContracts : declares product/service needs
ShellContracts --> HostComposition : validated declarations
HostComposition --> HostPolicy : asks for allow/deny
HostPolicy --> Diagnostics : denied capability status

HostPolicy --> DomainTruth : allowed request still needs semantic validation
DomainTruth --> Diagnostics : semantic rejection / domain diagnostics
DomainTruth --> AppFormation : accepted descriptor + source context
AppFormation --> ProductGraph : forms candidate product
FutureService --> ProductGraph : future supervised formation only
ProductGraph --> DomainTruth : adoption validation where required
ProductGraph --> Consumers : publish formed products
ProductGraph --> Diagnostics : product status
FutureService --> Diagnostics : service health/status

note right of ShellContracts
  editor_shell owns declaration shape.
  It must not own material, texture,
  procgen, render, app-service, or
  product payload semantics.
end note

note bottom of FutureService
  WR-038 declares ToolServiceKey
  dependencies only. Service protocol,
  process ABI, sandboxing, and external
  components remain future work.
end note

note bottom of DomainTruth
  Domains validate meaning.
  Host policy cannot grant semantic
  validity, and domain validation cannot
  grant host permission.
end note

note bottom of Diagnostics
  Desired declarations and observed status
  stay separate and inspectable.
end note

@enduml
