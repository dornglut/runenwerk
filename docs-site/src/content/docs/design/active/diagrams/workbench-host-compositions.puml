@startuml
title Workbench Host Compositions

skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Monospaced

package "Shared App-Neutral Contracts" as SharedPkg {
  component "domain/editor/editor_shell\nToolSuiteRegistry\nToolSurfaceRegistry\nWorkbenchHost contracts\nProvider route vocabulary" as ShellContracts
  component "Reusable app-support crates\noptional future host glue" as AppSupport
}

package "Full Runenwerk Editor\napps/runenwerk_editor" as FullPkg {
  component "WorkbenchHost" as FullHost
  component "Scene suite" as SceneSuite
  component "Material suite" as FullMaterialSuite
  component "Texture suite" as FullTextureSuite
  component "Asset suite" as AssetSuite
  component "Procgen suite" as ProcgenSuite
  component "Debug / product suites" as DebugSuites
  component "Self-authoring /\neditor-definition suites" as SelfAuthoringSuites
}

package "Standalone Material Editor\nfuture apps/*" as MaterialPkg {
  component "WorkbenchHost" as MaterialHost
  component "Material suite" as MaterialSuite
  component "Texture suite" as TextureSuite
  component "Product preview suite" as ProductPreviewSuite
  component "Diagnostics suite" as MaterialDiagnosticsSuite
  component "Minimal project IO" as MaterialProjectIo
  component "Render preview adapter" as MaterialRenderAdapter
}

package "Standalone UI Editor\nfuture apps/*" as UiPkg {
  component "WorkbenchHost" as UiHost
  component "UI layout suite" as UiLayoutSuite
  component "Theme editor suite" as ThemeSuite
  component "Menu editor suite" as MenuSuite
  component "Shortcut editor suite" as ShortcutSuite
  component "Command-binding suite" as CommandBindingSuite
  component "Shell preview /\nvalidation suite" as ShellPreviewSuite
}

FullHost --> ShellContracts
FullHost --> AppSupport
FullHost --> SceneSuite
FullHost --> FullMaterialSuite
FullHost --> FullTextureSuite
FullHost --> AssetSuite
FullHost --> ProcgenSuite
FullHost --> DebugSuites
FullHost --> SelfAuthoringSuites

MaterialHost --> ShellContracts
MaterialHost --> AppSupport
MaterialHost --> MaterialSuite
MaterialHost --> TextureSuite
MaterialHost --> ProductPreviewSuite
MaterialHost --> MaterialDiagnosticsSuite
MaterialHost --> MaterialProjectIo
MaterialHost --> MaterialRenderAdapter

UiHost --> ShellContracts
UiHost --> AppSupport
UiHost --> UiLayoutSuite
UiHost --> ThemeSuite
UiHost --> MenuSuite
UiHost --> ShortcutSuite
UiHost --> CommandBindingSuite
UiHost --> ShellPreviewSuite

note bottom of MaterialPkg
  Standalone editors are WorkbenchHost compositions.
  They must not fork or depend on apps/runenwerk_editor internals.
end note

note bottom of SharedPkg
  Shared contracts belong in domain/editor/editor_shell
  or dedicated reusable app-support crates.
  Concrete composition remains in apps/*.
end note

@enduml
