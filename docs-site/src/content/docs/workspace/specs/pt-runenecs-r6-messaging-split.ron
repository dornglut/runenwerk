PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R6",
    title: "Messaging Split and Tick-Buffer Migration",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS event/queue owner plus Runenwerk simulation/network tick-buffer owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
    ],
    complete_investigation_gate_status: "complete for semantic split; exact consumers require local search",
    complete_design_gate_status: "complete for retained events/queues and migrated tick buffers; implementation requires R5 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: ECS events, ECS FIFO queues, Runenwerk tick buffers",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/src/world/messaging/**",
        "domain/ecs/src/system/params.rs messaging params only",
        "domain/ecs/src/world/state.rs messaging fields only",
        "domain/ecs/src/world/runtime.rs explicit event finalization only",
        "domain/ecs/src/errors.rs messaging errors",
        "domain/ecs/src/lib.rs messaging exports",
        "domain/ecs/tests/broadcast*.rs",
        "domain/ecs/tests/work_queue*.rs",
        "domain/ecs/tests/tick_buffer*.rs",
        "net/engine_sim/** only for accepted tick-buffer owner/migration",
        "engine/src/plugins/net/** and net/engine_net/** only for current tick-buffer/queue consumer migration",
        "focused messaging integration tests and proof/closeout docs",
    ],
    forbidden_paths: [
        "network protocol/replication/prediction redesign",
        "generic task executor or acknowledgement/retry framework",
        "compatibility tick-buffer API in ECS",
        "spatial/reflection/query/scheduler/render/repository extraction",
        "new universal epoch-buffer crate",
    ],
    public_api_surface: [
        "RunenECS retains typed one-to-many events with host-neutral lifecycle and structured retention/lag/overflow outcomes.",
        "RunenECS retains deterministic typed FIFO world queues with explicit backpressure and destructive drain/clear operations.",
        "Simulation/network tick buffers and provenance move out of ECS into a named Runenwerk owner.",
        "No event/queue API implies transport, task execution, retry, priority, acknowledgement, or network semantics.",
    ],
    invariants: [
        "Event ordering and reader cursor behavior are deterministic.",
        "Normal capacity overflow never panics.",
        "Dropped/rejected/lagged outcomes are explicit and preserve payload where ownership requires it.",
        "FIFO queues retain exact order and return exact unaccepted payload under backpressure.",
        "Event lifecycle is finalized by an explicit host/runtime call, not an engine FrameEnd enum in core.",
        "Tick-buffer migration preserves simulation/network tick, deduplication, provenance, and retention behavior.",
        "No duplicate active tick-buffer authority remains in ECS.",
    ],
    acceptance_criteria: [
        "Broadcast/event tests cover multiple readers, retention loss, overflow, cleanup, and sequence exhaustion.",
        "Event storage avoids O(n) front removal for normal retention paths.",
        "Queue tests cover order, capacity, exact rejection payload, peek/read/drain/clear, and independent readers/writers as applicable.",
        "All current tick-buffer consumers migrate to the named Runenwerk simulation/network owner.",
        "ECS no longer owns current/finalized simulation tick or provenance buffers.",
        "Network runtime behavior remains proven without broad protocol changes.",
    ],
    validation_commands: [
        "activation-time rg for broadcast, work_queue, tick_buffer, current_tick, finalized_tick consumers",
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo test -p engine_sim --locked",
        "cargo test -p engine_net --locked",
        "focused engine network integration tests",
        "cargo clippy -p ecs -p engine_sim -p engine_net --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide complete messaging consumer map.",
        "Record final names/owners for events, queues, and tick buffers.",
        "Prove payload recovery, overflow, lag, ordering, and migration behavior.",
        "Prove no duplicate tick-buffer authority remains.",
        "Report protocol non-changes and validation honestly.",
    ],
    stop_conditions: [
        "Stop if current event/queue consumers rely on undocumented transport/task semantics.",
        "Stop if tick buffers have a proven second independent non-network consumer requiring design reconsideration.",
        "Stop if R5 spatial removal is incomplete.",
        "Stop if broad network protocol changes are required.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record retained/migrated/deleted API map, consumer migration, validation, forbidden-scope proof, and R7 prerequisites.",
    ],
    next_phase_activation_condition: "R7 requires accepted R6 messaging closeout and separate implementation authorization.",
)
