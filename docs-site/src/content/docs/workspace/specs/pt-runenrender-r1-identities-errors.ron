PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R1",
    title: "Neutral Renderer Identities Errors and Dependency Guards",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "neutral renderer core identity/error owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for target identity/error findings subject to exact local inventory",
    complete_design_gate_status: "complete for R1 target; implementation requires separate activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: IDs/errors/guards only",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/api/ids.rs",
        "engine/src/plugins/render/api/handles.rs",
        "engine/src/plugins/render/graph/diagnostics.rs",
        "engine/src/plugins/render/resource/lifetime.rs only for stale identity errors",
        "one internal neutral renderer module/crate manifest only if activation proves it enforces final dependency direction",
        "focused identity/error/dependency-guard tests",
        "proof and closeout docs",
    ],
    forbidden_paths: [
        "graph operation/resource descriptor redesign",
        "producer/frame/WGPU/surface/shader/product adapter changes",
        "external repository creation",
        "Runenwerk ID compatibility aliases",
        "global atomics as canonical graph identity",
        "universal ID/core crate",
    ],
    public_api_surface: [
        "Renderer-local opaque IDs are allocated by explicit owners/namespaces.",
        "Identity exhaustion and stale generation are structured errors.",
        "Initial structured renderer error families replace public anyhow/panic lookup behavior in scope.",
        "Runtime IDs are not persisted identities.",
    ],
    invariants: [
        "No target neutral identity depends on Runenwerk id/id_macros.",
        "No identity saturates into reuse.",
        "Cross-owner/namespace/stale IDs are rejected deterministically.",
        "No normal missing-label/handle condition panics.",
        "Dependency guards describe the final forbidden dependency set without changing unrelated behavior.",
    ],
    acceptance_criteria: [
        "Global canonical flow-ID allocation is removed or bounded behind explicit allocator ownership.",
        "Focused tests prove allocation, equality, namespace isolation, stale/exhausted rejection, and deterministic diagnostics.",
        "Public branchable failures use structured errors.",
        "Architecture/dependency tests prevent ECS/WGPU/Winit/Runenwerk/domain imports in the selected neutral boundary.",
        "No graph/backend/product semantic change enters R1.",
    ],
    validation_commands: [
        "mandatory renderer local inventory/baseline",
        "cargo +stable fmt --all --check",
        "focused engine renderer identity/error tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Map each old identity allocator/type/error path to the new owner.",
        "Prove exhaustion/stale/namespace behavior.",
        "Show dependency-guard scope and no product behavior change.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if identity repair requires graph or resource semantic redesign.",
        "Stop if an existing persisted format depends on current raw IDs.",
        "Stop if a neutral crate would be decorative and still reach engine internals.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record identity/error API, dependency guards, validation, scope proof, and R2 prerequisites.",
    ],
    next_phase_activation_condition: "R2 requires accepted R1 closeout and separate implementation authorization.",
)
