PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R5",
    title: "Shader Descriptor and Hot-Reload Boundary",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "neutral shader descriptor owner plus Runenwerk asset/hot-reload owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current mixed shader/filesystem authority subject to local source/consumer inventory",
    complete_design_gate_status: "complete for descriptor/reload split; implementation requires R4 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: neutral descriptors, future WGPU realization, Runenwerk filesystem policy",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/shader/**",
        "engine/src/plugins/render/pipelines/** only descriptor/key boundary",
        "engine/src/plugins/render/composition/hot_reload.rs",
        "asset/shader integration call sites required by the split",
        "internal neutral renderer shader descriptor modules/manifests",
        "focused descriptor/revision/reload tests",
        "proof and closeout docs",
    ],
    forbidden_paths: [
        "WGPU shader module/pipeline realization beyond descriptor test doubles",
        "material/SDF/UI/world/editor semantic shader families in neutral API",
        "filesystem paths/watchers inside neutral renderer modules",
        "silent invalid-flow/shader skipping",
        "external repository creation",
    ],
    public_api_surface: [
        "Neutral shader contracts contain identity, source kind/content, interface/binding expectations, revision, capabilities, and structured diagnostics.",
        "Runenwerk owns filesystem roots, paths, polling/watchers, asset lookup, and last-known-good policy.",
        "WGPU module/pipeline realization remains the R6 backend concern.",
        "Shader revisions are explicit inputs, not implicit filesystem state.",
    ],
    invariants: [
        "Neutral shader descriptors contain no filesystem or Runenwerk asset type.",
        "Equal source/interface/revision produces deterministic descriptor identity/report behavior.",
        "Invalid source/interface/revision produces structured errors and is not silently skipped.",
        "Hot reload never mutates core/backend state without an explicit accepted revision update.",
        "Last-known-good fallback is Runenwerk product policy and is observable.",
        "No material/SDF/UI semantic kind is required by renderer core.",
    ],
    acceptance_criteria: [
        "Shader registry descriptor logic builds/tests without filesystem access.",
        "File discovery/watch/poll/throttle/force-reload code is isolated in Runenwerk integration.",
        "Current shader consumers migrate to explicit descriptors/revisions.",
        "Invalid reload preserves or rejects according to explicit Runenwerk policy with diagnostics.",
        "Neutral pipeline keys do not contain product/material identities.",
        "No WGPU execution or domain-adapter migration enters the phase.",
    ],
    validation_commands: [
        "activation-time shader/path/watcher/consumer inventory",
        "cargo +stable fmt --all --check",
        "focused shader descriptor/revision/hot-reload tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative WGSL/Naga validation commands where applicable",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Map each shader registry/path/watch/reload responsibility to final owner.",
        "Prove descriptor determinism and invalid-source reporting.",
        "Prove neutral modules contain no filesystem/product types.",
        "Record current reload behavior and explicit fallback policy.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if WGPU realization must be implemented to define the descriptor boundary.",
        "Stop if current material/SDF/UI shader generation cannot be separated from generic descriptors.",
        "Stop if R4 GPU parameter ABI is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record shader descriptor API, hot-reload ownership, consumer migration, validation, and R6 prerequisites.",
    ],
    next_phase_activation_condition: "R6 requires accepted R5 shader-boundary closeout and separate implementation authorization.",
)
