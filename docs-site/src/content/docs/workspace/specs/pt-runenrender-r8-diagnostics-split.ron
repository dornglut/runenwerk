PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R8",
    title: "Generic Diagnostics Capture and Provenance Split",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenRender diagnostic/report owner plus Runenwerk product inspection owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current generic/product inspection mix subject to exact local module/export inventory",
    complete_design_gate_status: "complete for diagnostic split; implementation requires R7 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: generic renderer facts versus Runenwerk product evidence/presentation",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/inspect/**",
        "engine/src/plugins/render/graph/diagnostics.rs",
        "internal core/WGPU report and provenance modules",
        "Runenwerk debug/capture/artifact/export consumers required by the split",
        "focused deterministic report/capture tests",
        "proof and closeout docs",
    ],
    forbidden_paths: [
        "graph/backend semantic redesign beyond report integration",
        "product evidence types in neutral packages",
        "filesystem artifact/export paths in renderer packages",
        "inspection UI or editor workflow migration beyond consumer adaptation",
        "wall-clock telemetry as behavior authority",
        "external repository creation",
    ],
    public_api_surface: [
        "RunenRender exposes structured graph/pass/resource/producer/backend/surface/submission/provenance reports and diagnostics.",
        "Diagnostic codes use runenrender.* namespaces.",
        "Generic capture/readback facts contain renderer identities/data only.",
        "Runenwerk owns material/SDF/world/product/editor evidence, artifact paths/export policy, UI presentation, and startup/pacing policy.",
    ],
    invariants: [
        "Generic diagnostics do not contain Runenwerk domain/product types.",
        "Diagnostic identity/provenance remains stable and structured across adapter enrichment.",
        "External sinks/exporters cannot change renderer behavior or canonical reports.",
        "Wall-clock timings are observational and clearly environment-dependent.",
        "Capture/readback ownership and memory lifetime are explicit.",
        "Runenwerk adapters preserve upstream diagnostics and add context rather than replacing them.",
    ],
    acceptance_criteria: [
        "Every inspect module is classified and moved/retained accordingly.",
        "Neutral packages contain no SDF/material/world/product/editor evidence type or filesystem output path.",
        "Deterministic report/provenance snapshots pass without GPU where applicable.",
        "Backend/surface/submission report tests pass with structured diagnostics.",
        "Runenwerk capture/export/debug consumers preserve current product evidence through adapters.",
        "No diagnostics presentation or feature expansion enters renderer packages.",
    ],
    validation_commands: [
        "activation-time inspect/export/consumer inventory",
        "cargo +stable fmt --all --check",
        "focused core/WGPU report/provenance/capture tests",
        "focused Runenwerk product evidence/export tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide complete inspect module disposition and diagnostic code map.",
        "Prove neutral/product type separation and adapter enrichment.",
        "Record deterministic versus environment-dependent evidence separately.",
        "Record capture/export lifetime and behavior isolation.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if generic and product evidence cannot be separated without changing product semantics.",
        "Stop if capture/export behavior can mutate renderer authority.",
        "Stop if R7 surface/backend reports are incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record diagnostic/report APIs, module disposition, consumer migration, validation, and R9 prerequisites.",
    ],
    next_phase_activation_condition: "R9 requires accepted R8 diagnostics closeout and separate implementation authorization.",
)
