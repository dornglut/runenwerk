// Decision-complete implementation specification for the first internal RunenGPU boundary.
// S0 investigation and ADR 0015 remain architectural authority.

PhaseImplementationSpec(
    phase_id: "PT-RUNENGPU-G1A",
    title: "Logical GPU Work-Resource Identity",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "authorized-after-spec-merge",
    owner: "RunenGPU contract owner",

    source_baseline: "16d927deef7eb598a0eb632dbf8ec312b1ab9905",

    authority_docs: [
        "ARCHITECTURE.md",
        "DEPENDENCY_RULES.md",
        "DOMAIN_MAP.md",
        "docs-site/src/content/docs/adr/accepted/0015-separate-gpu-execution-from-rendering.md",
        "docs-site/src/content/docs/design/active/runengpu-architecture-design.md",
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runengpu-render-s0-inventory.md",
        "docs-site/src/content/docs/reports/investigations/runengpu-render-s0-file-disposition.md",
        "docs-site/src/content/docs/reports/investigations/runengpu-render-s0-identity-consumer-lifecycle.md",
        "docs-site/src/content/docs/workspace/planning/roadmap.md",
    ],

    goal: "Replace renderer-owned RenderResourceId and RenderResourceIdSequence with a future-transferable RunenGPU-owned GpuWorkResourceId and explicit fallible allocator, while preserving current graph and runtime behavior.",

    semantic_decisions: [
        "GpuWorkResourceId identifies one logical resource declared inside a bounded GPU work-graph construction context.",
        "It is not a concrete WGPU buffer, texture, view, sampler, bind group, pipeline, or backend allocation handle.",
        "It is not a render material, provider, view, target, feature, producer, source asset, persisted object, replay identity, network identity, wire value, or cross-process cache key.",
        "The first implementation lives under engine::plugins::gpu as an internal future-transferable RunenGPU boundary.",
        "G1A does not create a GpuPlugin, external package, facade, macro package, compatibility module, or backend abstraction.",
        "The implementation does not use id_macros::id because that macro generates safe arbitrary raw construction and TryFrom<u64>.",
        "The old RenderResourceId and RenderResourceIdSequence names are deleted in the same migration; no alias or forwarding re-export remains.",
    ],

    target_module_shape: [
        "engine/src/plugins/gpu/mod.rs",
        "engine/src/plugins/gpu/api/mod.rs",
        "engine/src/plugins/gpu/api/work_resource_id.rs",
        "engine/src/plugins/gpu/api/errors.rs only if the identity and allocator error cannot remain coherently colocated",
        "engine/src/plugins/mod.rs only to expose the internal gpu module and reviewed public re-exports",
    ],

    public_contract: [
        "pub struct GpuWorkResourceId with a private nonzero scalar representation.",
        "GpuWorkResourceId is Clone, Copy, Eq, Ord, Hash, Debug, and Display.",
        "Safe production API exposes no public try_from_raw, from_raw, new_unchecked, TryFrom<u64>, From<u64>, or equivalent arbitrary-construction path.",
        "A read-only raw() or diagnostic_value() accessor may return u64 only for diagnostics, ordering, hashing, and trace correlation and must document that no stable-format guarantee exists.",
        "pub struct GpuWorkResourceIdAllocator owns explicit next-allocation state.",
        "Allocator construction is valid without process-global state and begins at the first admitted nonzero value.",
        "allocate() returns Result<GpuWorkResourceId, GpuWorkResourceIdAllocationError>.",
        "Exhaustion is explicit and never wraps, saturates into reuse, or panics through the public fallible path.",
        "Allocation is deterministic for the same allocator state and operation order.",
        "The identity is graph-local by ownership and API placement; G1A does not invent a separate graph-id field or generational representation without evidence.",
    ],

    error_contract: [
        "GpuWorkResourceIdAllocationError::Exhausted or an equivalently precise owned variant.",
        "Errors are structured, comparable where useful, and Display-capable without caller branching on strings.",
        "No anyhow, boxed dynamic error, panic, unwrap, expect, or silent fallback in the public allocation path.",
        "No public invalid-start constructor is required if the allocator exposes only a valid default/new state.",
    ],

    exact_consumer_inventory: [
        "apps/runenwerk_editor/src/runtime/viewport/render_jobs.rs",
        "engine/src/plugins/render/api/bindings.rs",
        "engine/src/plugins/render/api/flow.rs",
        "engine/src/plugins/render/api/handles.rs",
        "engine/src/plugins/render/api/ids.rs",
        "engine/src/plugins/render/api/passes.rs",
        "engine/src/plugins/render/backend/resource_allocator.rs",
        "engine/src/plugins/render/frame/packet.rs",
        "engine/src/plugins/render/gpu_primitives/compaction.rs",
        "engine/src/plugins/render/gpu_primitives/counters.rs",
        "engine/src/plugins/render/gpu_primitives/draw_args.rs",
        "engine/src/plugins/render/gpu_primitives/plan.rs",
        "engine/src/plugins/render/gpu_primitives/scan.rs",
        "engine/src/plugins/render/graph/capabilities.rs",
        "engine/src/plugins/render/graph/diagnostics.rs",
        "engine/src/plugins/render/graph/execution_plan.rs",
        "engine/src/plugins/render/graph/pass_graph.rs",
        "engine/src/plugins/render/graph/planning.rs",
        "engine/src/plugins/render/graph/prepared_validation.rs",
        "engine/src/plugins/render/graph/resource_graph.rs",
        "engine/src/plugins/render/graph/resource_lifetimes.rs",
        "engine/src/plugins/render/graph/validation.rs",
        "engine/src/plugins/render/procedural/authoring.rs",
        "engine/src/plugins/render/procedural/descriptors.rs",
        "engine/src/plugins/render/procedural/population/uniform_grid.rs",
        "engine/src/plugins/render/renderer/render_flow/execute_passes.rs",
        "engine/src/plugins/render/renderer/render_flow/runtime_resources.rs",
        "engine/src/plugins/render/renderer/render_flow/runtime_resources/realize.rs",
        "engine/src/plugins/render/renderer/render_flow/runtime_resources/resolve.rs",
        "engine/src/plugins/render/resource/descriptors.rs",
        "engine/src/plugins/render/resource/import.rs",
        "engine/src/plugins/render/resource/transient.rs",
        "engine/src/plugins/render/resource/usages.rs",
        "engine/src/plugins/render/runtime/frame_prepare.rs",
        "engine/tests/render_dynamic_targets.rs",
        "engine/tests/render_import_contract.rs",
        "engine/tests/render_resource_model.rs",
        "engine/tests/render_runtime_inspect.rs",
    ],

    allowed_paths: [
        "engine/src/plugins/gpu/** for the new identity, allocator, focused tests, and dependency guards",
        "engine/src/plugins/mod.rs for gpu module exposure and reviewed re-exports",
        "engine/src/plugins/render/api/ids.rs only to remove RenderResourceId while retaining unrelated current IDs",
        "the exact 38 consumer files listed in exact_consumer_inventory for mechanical type/import/allocation/error migration",
        "engine/src/prelude.rs only if current RenderResourceId is publicly re-exported there and the replacement must preserve current public reachability",
        "focused compile-fail/source-guard tests owned by engine",
        "docs-site/src/content/docs/reports/proofs/pt-runengpu-g1a-*.md",
        "docs-site/src/content/docs/reports/closeouts/pt-runengpu-g1a-closeout.md only after implementation merges",
        "roadmap, active-work, decision-register, and phase-spec status updates required for closeout",
    ],

    forbidden_scope: [
        "RenderFlowId, RenderPassId, RenderFeatureId, RenderFrameProducerId, RenderSurfaceId, RenderFixedStepRegionId, or any other identity migration",
        "foundation/id or foundation/id_macros redesign",
        "GpuPlugin creation or plugin lifecycle behavior",
        "render graph node, pass, dependency, capability, hazard, validation, scheduling, fixed-step, or product semantic redesign",
        "WGPU instance, adapter, device, queue, resource, pipeline, command, upload, readback, surface, or device-loss behavior",
        "shader, pipeline, macro ABI, material, SDF, UI, editor, procgen, world, cave, VFX, capture, diagnostics presentation, or product feature redesign",
        "external runen-gpu or runen-render repository source movement",
        "Cargo package creation, workspace member changes, dependency additions, or lockfile changes unless an existing now-unused render-only dependency is proven removable and separately reviewed",
        "compatibility aliases, deprecated parallel names, forwarding modules, source includes, or duplicate allocators",
        ".github/** and workflow changes",
    ],

    mechanical_migration: [
        "RenderResourceId -> GpuWorkResourceId",
        "RenderResourceIdSequence -> GpuWorkResourceIdAllocator",
        "per-RenderFlow next_resource_id state remains per-flow allocator state with the new type",
        "typed handles continue to store the logical resource identity and existing metadata without semantic change",
        "resource descriptors, imports, usages, lifetimes, graph records, execution plans, runtime resource maps, and diagnostics migrate type names only",
        "tests and application consumers migrate imports and constructors without compatibility shims",
        "raw test construction is replaced by allocation through focused test helpers or the real allocator; production arbitrary raw construction is not retained for test convenience",
    ],

    invariants: [
        "Zero is never a valid GpuWorkResourceId.",
        "Two successful allocations from one allocator are distinct and monotonically ordered.",
        "The same explicit allocator state and operation sequence produces the same values.",
        "Exhaustion returns a structured error and leaves no reused or wrapped valid identity.",
        "Safe external code cannot forge an arbitrary GpuWorkResourceId from an integer.",
        "Diagnostic raw values are not stable source, persistence, replay, network, wire, or cache identities.",
        "GpuWorkResourceId remains distinct from every render, product, surface, shader, pipeline, and backend handle type.",
        "No current graph, rendering, WGPU, application, or product behavior changes beyond the identity type and allocation error propagation required by the migration.",
        "The new gpu identity module imports no render module, ECS, WGPU, Winit, RunenSDF, RunenUI, scene, material, editor, procgen, world, application, or product type.",
        "No old RenderResourceId or RenderResourceIdSequence declaration, alias, import, export, or consumer remains after completion.",
    ],

    required_tests: [
        "first allocation is nonzero",
        "deterministic monotonic allocation order",
        "multiple allocations are distinct",
        "explicit exhaustion without wrap, saturation, reuse, or panic",
        "identity equality, ordering, hashing, Debug, and Display",
        "no public arbitrary raw-construction API through compile-fail or source guard",
        "type distinction from remaining RenderFlowId, RenderPassId, and backend handles",
        "existing typed handle tests after migration",
        "existing resource descriptor/import/lifetime/graph/runtime tests remain behaviorally unchanged",
        "source guard rejects forbidden imports in engine/src/plugins/gpu",
        "repository search proves zero remaining RenderResourceId and RenderResourceIdSequence references",
    ],

    acceptance_criteria: [
        "engine::plugins::gpu owns GpuWorkResourceId, its allocator, and structured allocation error.",
        "RenderResourceId and RenderResourceIdSequence are deleted without aliases.",
        "All 38 inventoried consumer files are either mechanically migrated or proven not to require a diff after current-main recheck.",
        "No additional consumer is discovered outside the exact inventory; if one exists, the implementation PR updates its inventory before code changes continue.",
        "No stable-format use of the old raw value exists.",
        "All focused, engine, workspace, documentation, and repository-audit validation passes.",
        "The implementation diff contains no forbidden-scope behavior or unrelated identity migration.",
    ],

    validation_commands: [
        "git status --short --branch",
        "git rev-parse HEAD",
        "cargo metadata --format-version 1 --locked --no-deps",
        "rg -n 'RenderResourceId|RenderResourceIdSequence|GpuWorkResourceId|GpuWorkResourceIdAllocator|try_from_raw|\\.raw\\(' engine apps domain net adapters --glob '*.rs'",
        "rg -n 'wgpu::|winit::|ecs::|plugins::render|material_graph|world_sdf|runenui|ui_|editor|procgen|scene|product' engine/src/plugins/gpu",
        "cargo +stable fmt --all --check",
        "cargo test -p engine gpu_work_resource_id --locked",
        "cargo test -p engine render_resource --locked",
        "cargo test -p engine --lib --locked",
        "cargo test -p engine --tests --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "cargo validate",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report the exact current-main declaration, sequence, allocation, import, export, handle, descriptor, graph, renderer, application, and test inventory before editing Rust.",
        "Report any consumer added or removed since the specification baseline.",
        "Report the final public type and allocator API without exposing arbitrary raw construction.",
        "Report allocation and exhaustion tests, including the technique used to reach exhaustion without widening production API.",
        "Report every mechanical consumer migration and every unchanged inventoried file with justification.",
        "Report the dependency/source guard and all forbidden-import results.",
        "Report zero remaining old-name references and zero compatibility aliases.",
        "Separate deterministic contract evidence from unavailable environment-dependent GPU evidence.",
    ],

    stop_conditions: [
        "Any consumer intentionally persists, serializes, replays, transmits, or uses raw RenderResourceId as a stable cross-process value.",
        "The migration requires RenderPassId, RenderFlowId, RenderSurfaceId, or another identity redesign.",
        "The migration requires graph semantic, WGPU realization, shader, surface, window, or renderer behavior changes.",
        "A compatibility alias or duplicate old/new allocator is required to keep the branch compiling.",
        "The new gpu module would depend on renderer, ECS, WGPU, Winit, or domain/product types.",
        "Current main fails the canonical baseline for unrelated reasons.",
        "The exact consumer inventory is incomplete or materially changed before implementation begins.",
    ],

    closeout_expectations: [
        "Record final module/API shape, exact changed files, consumer migrations, allocator behavior, tests, dependency guards, validation evidence, scope proof, known gaps, and next safe action.",
        "Do not activate G1B/G2 until G1A is reviewed, merged, and closed against current main.",
        "Write the next specification only from merged G1A facts rather than pre-authoring later GPU contracts.",
    ],

    next_phase_activation_condition: "A later RunenGPU phase may enter planning only after PT-RUNENGPU-G1A implementation is exact-head validated, reviewed, merged, and closed with no old identity authority remaining.",
)
