PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R2",
    title: "Neutral Graph and Resource Descriptors",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "neutral render graph and resource-planning owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for known graph contamination subject to exact local module/test inventory",
    complete_design_gate_status: "complete for neutral operation/resource target; implementation requires R1 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: graph/resource planning only",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/graph/**",
        "engine/src/plugins/render/resource/**",
        "engine/src/plugins/render/api/passes.rs",
        "engine/src/plugins/render/api/resources.rs",
        "engine/src/plugins/render/api/ids.rs only for R1 identity use",
        "internal neutral renderer graph/resource modules/manifests established by R1",
        "focused graph/resource tests and proof/closeout docs",
    ],
    forbidden_paths: [
        "frame producer/prepared-input migration",
        "WGPU backend/surface/shader implementation",
        "Runenwerk feature/material/SDF/UI/editor/runtime migration",
        "fixed-time compatibility layer in core",
        "BuiltinUiComposite or any renamed product pass",
        "external repository creation",
    ],
    public_api_surface: [
        "Core operations are Compute, Graphics, FullscreenRaster, Copy, and Present only.",
        "Graph/resource descriptors contain explicit validated values and repository-local IDs.",
        "Compiled plans contain no ECS TypeId state access, fixed-time regions, product views, or feature semantics.",
        "Validation/build failures use structured graph/resource errors.",
    ],
    invariants: [
        "Graph planning is deterministic and GPU-free.",
        "No core graph/resource module imports ECS, WGPU, Winit, Runenwerk domains, UI, SDF, scene, or material authoring.",
        "Cycles, missing references, duplicate IDs, access conflicts, invalid bindings, and lifetime errors are rejected before execution.",
        "Resource sizes/usages/formats/lifetimes are validated without silent saturation into invalid state.",
        "Product producers validate semantics before generic submission.",
    ],
    acceptance_criteria: [
        "Builtin UI validation/pass/feature dependencies are absent from core graph.",
        "Host TypeId/state-driven dispatch and fixed-step plan nodes are absent.",
        "MainSurface/OffscreenProduct categories are absent from core.",
        "Graph tests instantiate no ECS World and no WGPU device.",
        "Generic compute/graphics/copy/present plan snapshots are deterministic.",
        "Existing product behavior remains compiling through bounded temporary Runenwerk adapters without permanent compatibility APIs.",
    ],
    validation_commands: [
        "cargo +stable fmt --all --check",
        "focused graph/resource tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "rg -n 'BuiltinUi|UI_RENDER_FEATURE_ID|TypeId|FixedStep|MainSurface|OffscreenProduct|ecs::|wgpu::|winit::' selected neutral graph/resource paths",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide operation/resource old-to-new map and removed product variants.",
        "Provide deterministic graph validation matrix.",
        "Prove forbidden dependency absence.",
        "Record temporary adapter seams and their mandatory removal phase.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if product semantics cannot be removed without first defining prepared inputs/producers in the same phase.",
        "Stop if a broad renderer rewrite beyond graph/resource planning is required.",
        "Stop if R1 identity/error foundation is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record final neutral graph/resource surface, removed coupling, tests, temporary seams, validation, and R3 prerequisites.",
    ],
    next_phase_activation_condition: "R3 requires accepted R2 graph/resource closeout and separate implementation authorization.",
)
