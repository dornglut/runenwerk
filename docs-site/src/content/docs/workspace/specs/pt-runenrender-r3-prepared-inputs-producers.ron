PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R3",
    title: "Explicit Prepared Frame Inputs and Generic Producers",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "neutral frame input and producer-contribution owner plus Runenwerk state-projection migration owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current state-projection/product contribution findings subject to local consumer inventory",
    complete_design_gate_status: "complete for explicit-input/producer target; implementation requires R2 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: neutral frame/producers versus Runenwerk projection/product policy",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/frame/**",
        "engine/src/plugins/render/api/flow.rs",
        "engine/src/plugins/render/api/dispatch.rs",
        "engine/src/plugins/render/composition/fragments.rs",
        "engine/src/plugins/render/composition/fragment_validation.rs",
        "internal neutral renderer frame/producer modules/manifests",
        "Runenwerk state-projection/product-selection call sites required for migration",
        "focused producer/frame tests and proof/closeout docs",
    ],
    forbidden_paths: [
        "WGPU backend/surface/shader realization",
        "material/SDF/UI/scene/editor semantic adapter migration beyond generic test fixtures",
        "fixed-step region compatibility in core",
        "ECS callbacks or host TypeId storage inside prepared plans",
        "built-in product feature registry",
        "external repository creation",
    ],
    public_api_surface: [
        "Prepared frame input contains explicit validated uniforms, storage data, buffers, textures, draw/dispatch arguments, views, targets, and invocations.",
        "Generic producers contribute passes/resources/updates with producer identity, provenance, ordering, capabilities, and deterministic upsert/remove behavior.",
        "Core plans never call back into ECS/application state.",
        "Views and targets are generic opaque IDs/descriptors without product semantics.",
    ],
    invariants: [
        "Equal prepared inputs and graph state produce equal deterministic plans/reports.",
        "Producer replacement/removal cannot leave stale contributions.",
        "Missing/stale resources, views, targets, or producers are structured errors.",
        "Prepared input ownership/lifetime is explicit through frame execution.",
        "Runenwerk resolves fixed-time and product-selection policy before renderer submission.",
        "No UI/SDF/material/scene/editor semantic type appears in the generic producer contract.",
    ],
    acceptance_criteria: [
        "with_state/uniform_from_state/dispatch_from_state and equivalent host callbacks are absent from neutral core.",
        "Product view categories and feature IDs are absent from neutral frame contracts.",
        "Producer upsert/replacement/removal/order/capability tests pass without engine world.",
        "Runenwerk fixed-step behavior is represented by explicit repeated invocations/prepared values.",
        "Current producers compile through bounded Runenwerk translation seams with no permanent compatibility API.",
        "Frame-input validation rejects incomplete/inconsistent submissions before backend execution.",
    ],
    validation_commands: [
        "activation-time producer/state-projection consumer inventory",
        "cargo +stable fmt --all --check",
        "focused frame/producer tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "rg -n 'with_state|uniform_from_state|dispatch_from_state|TypeId|MainSurface|OffscreenProduct|UI_RENDER_FEATURE_ID' selected neutral paths",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide complete old state-projection and producer migration map.",
        "Prove deterministic prepared-input and producer lifecycle behavior.",
        "Prove semantic-type absence from generic contracts.",
        "Record temporary seams and R9 removal ownership.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if a current producer cannot be represented without adding domain semantics to core.",
        "Stop if prepared-input lifetime requires unresolved backend ownership changes.",
        "Stop if R2 neutral graph/resource work is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record public frame/producer contracts, migrated producers, temporary seams, validation, and R4 prerequisites.",
    ],
    next_phase_activation_condition: "R4 requires accepted R3 frame/producer closeout and separate implementation authorization.",
)
