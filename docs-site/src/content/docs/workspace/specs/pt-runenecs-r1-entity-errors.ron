PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R1",
    title: "Entity Identity and Structured Core Errors",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS entity allocator and world lifecycle owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
        "docs-site/src/content/docs/architecture/repository-family-architecture.md",
        "docs-site/src/content/docs/guidelines/programming-principles.md",
    ],
    complete_investigation_gate_status: "complete subject to mandatory local file/consumer/baseline verification",
    complete_design_gate_status: "complete for R1 target; implementation requires separate activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: entity allocator/world lifecycle only",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/src/entity.rs",
        "domain/ecs/src/errors.rs",
        "domain/ecs/src/world/entity/**",
        "domain/ecs/src/world/state.rs only for entity allocator/world identity wiring",
        "domain/ecs/src/lib.rs only for corrected entity/error exports",
        "domain/ecs/tests/entity_identity*.rs",
        "domain/ecs/tests/world_error*.rs",
        "focused consumer migrations required by private Entity fields",
        "proof and closeout docs for PT-RUNENECS-R1",
    ],
    forbidden_paths: [
        "bundle/command semantic changes beyond compilation migration",
        "query or SystemParam unsafe-boundary changes",
        "reflection, messaging, spatial, ownership, change extraction, scheduler, networking, renderer, or repository extraction",
        "parallel execution",
        "compatibility entity type or public raw-field alias",
        "foundation/meta or universal ID crate",
    ],
    public_api_surface: [
        "Entity becomes an opaque world-local generational value with private fields.",
        "Read-only identity access is exposed only where current public diagnostics require it.",
        "Entity/world lifecycle failures use structured errors.",
        "Raw entity values are not stable persistence or network identities.",
    ],
    invariants: [
        "Stale and double-free entities are rejected deterministically.",
        "Generation exhaustion retires a slot permanently and never saturates into reuse.",
        "Failed spawn/despawn/free preflight in this scope leaves allocator/world liveness unchanged.",
        "Cross-world identity behavior is explicit and tested if current APIs permit entity transfer.",
        "No ordinary invalid entity operation panics.",
    ],
    acceptance_criteria: [
        "Entity fields are private and no active consumer constructs Entity literals.",
        "Allocator reuse preserves generation safety.",
        "Exhausted slots are proven retired.",
        "Stale, double-free, unknown, and cross-world cases have structured tests.",
        "Networking continues to map entities through explicit product IDs rather than treating raw Entity as stable identity.",
        "Focused and full ECS tests pass without unrelated semantic changes.",
    ],
    validation_commands: [
        "mandatory PT-RUNENECS-001 local inventory and baseline",
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo clippy -p ecs --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Map every Entity literal/field consumer and migration.",
        "Prove stale/double-free/exhaustion behavior and unchanged state on rejection.",
        "Report structured error taxonomy and removed panic/anyhow paths.",
        "Report exact validation and skipped commands honestly.",
    ],
    stop_conditions: [
        "Stop if persisted/network formats directly encode raw Entity without an accepted migration design.",
        "Stop if cross-world identity requires a broader namespace redesign not covered here.",
        "Stop if bundle/query/reflection/scheduler rewrites are required.",
        "Stop while implementation authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record API migration, changed files, proof matrix, validation, forbidden-scope proof, and remaining R2 dependencies.",
    ],
    next_phase_activation_condition: "R2 may enter implementation only after R1 is reviewed, merged, and truthfully closed; R2 still requires separate authorization.",
)
