PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R10",
    title: "Internal Public-Boundary Conformance and Performance Proof",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenRender internal package conformance and Runenwerk integration owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
        "TESTING.md",
    ],
    complete_investigation_gate_status: "complete for target proof families subject to exact local test/benchmark/platform inventory",
    complete_design_gate_status: "complete for R10 target; implementation requires R9 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: internal package guards, public downstream conformance, headless/GPU proof, benchmarks",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "internal renderer package manifests and dependency guards established by R1-R9",
        "core/macros/WGPU tests and fixtures",
        "one external generic producer conformance package",
        "headless/offscreen examples/tests",
        "Runenwerk public-seam integration tests",
        "renderer planning/backend benchmarks",
        "docs-site/src/content/docs/engine/render/** current boundary alignment",
        "proof and closeout docs",
        "narrow production fixes only after an activation correction names exact paths and proves a conformance-found defect",
    ],
    forbidden_paths: [
        "external RunenRender repository creation",
        "Git dependency or source deletion",
        "new renderer feature families",
        "compatibility renderer/facade/private reach-through",
        "RunenUI/RunenSDF/RunenECS implementation",
        "widening production APIs solely for tests",
        "unsupported performance claims",
    ],
    public_api_surface: [
        "No broad new API; public downstream fixtures consume the accepted core/macros/WGPU contracts only.",
        "Runenwerk consumes internal renderer packages through the exact intended external public boundary.",
        "Core builds/tests without engine or GPU; WGPU builds/tests without engine or Winit.",
        "External generic producer defines resources/passes/frame inputs without product semantics.",
    ],
    invariants: [
        "Internal package dependency graph matches the accepted external repository graph.",
        "No renderer package imports ECS, Runenwerk, RunenSDF, RunenUI, scene, world, material authoring, editor, or Winit.",
        "No Runenwerk adapter uses renderer private modules.",
        "Deterministic core reports are separated from environment-dependent GPU measurements.",
        "One active rendering path remains and all temporary compatibility seams are gone.",
        "Benchmarks do not change behavior or become merge gates without accepted budgets.",
    ],
    acceptance_criteria: [
        "Dependency and source guards prove forbidden imports absent.",
        "External producer conformance passes using public APIs only.",
        "Core graph/resource/frame/producer tests pass without engine/WGPU.",
        "Macro ABI compile fixtures pass with renamed dependencies.",
        "WGPU headless compute/offscreen/upload/readback tests pass in supported environments.",
        "Surface/multi-surface/error/device-loss proofs pass where supported.",
        "Runenwerk application/headless/GPU tests use public seams only.",
        "Planning and backend benchmark baselines record environment and variance without unsupported guarantees.",
        "Exact move/stay/delete repository-transfer inventory is complete.",
        "No narrow proof fix expands scope without an activation correction.",
    ],
    validation_commands: [
        "cargo +stable fmt --all --check",
        "cargo metadata --format-version 1 --locked",
        "cargo tree for every internal renderer package and engine",
        "public core/macros/WGPU/downstream test commands",
        "repository-authoritative shader validation",
        "repository-authoritative headless WGPU commands",
        "repository-authoritative surface/GPU runtime evidence commands",
        "cargo clippy for every renderer package and engine --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "renderer benchmark no-run and selected baseline commands",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide exact dependency graph and forbidden import/private-access proof.",
        "Provide public downstream producer coverage matrix.",
        "Record core determinism separately from GPU environment evidence.",
        "Record OS/adapter/backend/device/features/limits for every GPU run.",
        "Record benchmark hardware/software/configuration and variance.",
        "Provide exact repository transfer inventory and provenance input.",
        "Report unavailable/skipped commands honestly.",
    ],
    stop_conditions: [
        "Stop if any renderer package retains a forbidden dependency or product semantic.",
        "Stop if Runenwerk still uses private renderer internals or a second render path.",
        "Stop if R1-R9 are not truthfully complete.",
        "Stop if changed GPU behavior lacks runtime evidence.",
        "Stop if conformance exposes a design defect requiring a separate repair phase.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record dependency/public-boundary proof, deterministic and GPU conformance, benchmark baseline, transfer inventory, validation, and repository-creation readiness.",
        "Do not activate external repository transfer until R10 is reviewed, merged, and closed.",
    ],
    next_phase_activation_condition: "PT-RUNENRENDER-006 repository creation/transfer planning begins only after R1-R10 are merged and closed; implementation also requires repository creation availability and separate authorization.",
)
