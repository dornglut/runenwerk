PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R4",
    title: "Explicit Reflection Registry and Macro Migration",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS reflection registry and macro owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
    ],
    complete_investigation_gate_status: "complete for current explicit/global registry and derive paths subject to local consumer verification",
    complete_design_gate_status: "complete for explicit registry target; implementation requires R3 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: reflection values/registry, world wiring, and derives",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/src/reflect/**",
        "domain/ecs/src/world/state.rs only for explicit registry ownership",
        "domain/ecs/src/world/mod.rs only for constructor/API wiring",
        "domain/ecs/src/errors.rs for reflection errors",
        "domain/ecs/src/lib.rs only for reflection exports",
        "domain/ecs_macros/src/lib.rs reflection derives only",
        "domain/ecs/tests/reflect*.rs",
        "domain/ecs_macros tests/fixtures for reflection and package renaming",
        "focused consumer migrations and proof/closeout docs",
    ],
    forbidden_paths: [
        "process-global reflection replacement under another name",
        "implicit inventory/linker/global registration",
        "stable serialization format or schema registry beyond validated stable keys",
        "query, messaging, spatial, ownership, scheduler, network, renderer, or repository extraction",
        "compatibility global registration API",
    ],
    public_api_surface: [
        "TypeRegistry is explicitly constructed and owned or borrowed by World/context.",
        "Rust TypeId, registry-local ReflectTypeId, and validated StableTypeKey are distinct.",
        "Macros produce descriptors or explicit registration operations, never global mutation.",
        "Duplicate stable keys and incompatible registrations return structured errors.",
        "Registry-local IDs are not durable serialized identities.",
    ],
    invariants: [
        "No OnceLock/Mutex/process-global mutable reflection authority remains.",
        "Two registries can coexist independently in one process/test.",
        "Duplicate stable keys never silently replace prior entries.",
        "Registration order is deterministic where observable.",
        "World registry lifetime and unload/reload behavior are explicit.",
        "Macros emit only supported RunenECS paths and preserve generics/where clauses.",
    ],
    acceptance_criteria: [
        "Global registry functions and compatibility aliases are removed.",
        "World construction or configuration makes registry ownership explicit.",
        "Registry isolation, duplicate, missing, and incompatible registration tests pass.",
        "External derives register descriptors explicitly and support renamed dependencies.",
        "No reflection lock poisoning or ordinary registration conflict panics.",
        "No persisted-schema claim is introduced beyond validated key vocabulary.",
    ],
    validation_commands: [
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo test -p ecs_macros --locked when supported",
        "cargo clippy -p ecs -p ecs_macros --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "rg -n 'OnceLock|global_type_registry|register_global' domain/ecs domain/ecs_macros .",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "List removed global authority and all migrated consumers.",
        "Prove two isolated registries and duplicate rejection.",
        "Prove external derive and dependency-renaming behavior.",
        "Document identity lifetime/serialization status.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if a current product depends on automatic global registration without an accepted explicit migration.",
        "Stop if stable schema/version work is required beyond this registry boundary.",
        "Stop if R3 unsafe bridge remains unresolved.",
        "Stop if implementation needs unrelated query/messaging/network work.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record registry API, macro migration, consumer changes, validation, forbidden-scope proof, and R5 prerequisites.",
    ],
    next_phase_activation_condition: "R5 requires accepted R4 reflection closeout and separate implementation authorization.",
)
