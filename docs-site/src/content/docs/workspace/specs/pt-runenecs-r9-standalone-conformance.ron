PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R9",
    title: "Standalone Conformance and Benchmark Baseline",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS public conformance and release-readiness owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
        "TESTING.md",
    ],
    complete_investigation_gate_status: "complete for target conformance families subject to local exact test/benchmark inventory",
    complete_design_gate_status: "complete for R9 target; implementation requires R8 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: tests/downstream fixtures/benchmarks/docs only plus narrow proof-driven fixes",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/tests/**",
        "domain/ecs/benches/**",
        "domain/ecs_macros tests/fixtures/**",
        "domain/scheduler tests/**",
        "domain/scheduler benches/** when present",
        "tests/runenecs_external/** or one accepted non-publishable downstream conformance package",
        "examples/runenecs_standalone/** or one accepted standalone simulation example",
        "docs-site/src/content/docs/domain/ecs/** current public API alignment",
        "proof and closeout docs",
        "narrow production fixes only when a proof exposes a defect and an activation correction names exact paths",
    ],
    forbidden_paths: [
        "external RunenECS repository creation",
        "package renaming or Git dependencies",
        "source deletion",
        "new framework feature families",
        "parallel executor implementation",
        "spatial/network/render/UI/product expansion",
        "widening production APIs solely for tests",
        "compatibility packages",
    ],
    public_api_surface: [
        "No new broad public API; tests consume the accepted RunenECS/RunenSchedule surface from outside the package.",
        "A downstream package defines components, resources, bundles, systems, system params, and reflection descriptors using public APIs only.",
        "A standalone simulation uses no engine or Runenwerk types.",
        "Generated macros support renamed package dependencies.",
    ],
    invariants: [
        "All earlier R1-R8 ownership and safety boundaries remain intact.",
        "Conformance does not use private modules or test-only production escape hatches.",
        "Miri/sanitizer tests exercise unsafe query/system-param/storage paths.",
        "Benchmarks measure representative operations without becoming correctness authority.",
        "RunenECS and RunenSchedule contain no geometry or Runenwerk dependency.",
        "Validation is locked, reproducible, and includes MSRV.",
    ],
    acceptance_criteria: [
        "Entity, atomicity, storage, query, command, event, queue, reflection, schedule, and macro conformance passes through public APIs.",
        "Standalone simulation completes deterministically without engine.",
        "External package compiles/tests with renamed dependencies.",
        "Miri/sanitizer focused suite passes or a reviewed platform limitation is recorded with an alternative safety gate.",
        "Stable and MSRV workspace tests plus denied-warning Clippy pass.",
        "Benchmark baseline records entity allocation, component mutation, queries, commands, scheduling, events, and queues.",
        "Exact move/stay/delete transfer inventory for RunenECS repository is complete.",
        "No narrow proof fix expands scope without an activation correction.",
    ],
    validation_commands: [
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo test -p scheduler --all-features --locked",
        "cargo test -p ecs_macros --locked when supported",
        "cargo test -p runenecs_external --locked or accepted downstream package command",
        "cargo run -p runenecs_standalone --locked or accepted standalone example command",
        "cargo clippy -p ecs -p scheduler -p ecs_macros --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative Miri/sanitizer commands",
        "repository-authoritative MSRV tests",
        "cargo bench -p ecs --no-run --locked",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide public downstream API coverage matrix.",
        "Record standalone simulation inputs and deterministic outputs.",
        "Record Miri/sanitizer toolchain/platform/results.",
        "Record benchmark environment and baseline without unsupported performance claims.",
        "Provide exact repository transfer inventory and dependency graph.",
        "Report all validation and skipped commands honestly.",
    ],
    stop_conditions: [
        "Stop if any proof requires private framework access or test-only production widening.",
        "Stop if R1-R8 are not truthfully complete.",
        "Stop if geometry/Runenwerk dependencies remain.",
        "Stop if unresolved unsafe behavior lacks an accepted validation path.",
        "Stop if a benchmark exposes a correctness defect requiring a separate fix.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record conformance matrix, safety evidence, benchmark baseline, transfer inventory, validation, and repository-creation readiness.",
        "Do not activate external repository transfer until R9 is reviewed, merged, and closed.",
    ],
    next_phase_activation_condition: "PT-RUNENECS-004 repository creation/transfer planning begins only after all R1-R9 repairs and conformance are merged and closed; implementation also requires repository creation availability and separate authorization.",
)
