PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R4",
    title: "GPU Parameters and Renderer Macro ABI Conformance",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenRender GPU parameter and proc-macro owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current GpuUniform/GpuStorage derives subject to exact local fixture inventory",
    complete_design_gate_status: "complete for macro/package target; implementation requires R3 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: GPU value/layout traits and proc macros only",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/params/**",
        "engine_render_macros/**",
        "internal neutral renderer GPU parameter modules/manifests",
        "focused ABI/layout tests",
        "external compile-pass/compile-fail fixture package",
        "proof and closeout docs",
    ],
    forbidden_paths: [
        "shader filesystem/hot reload",
        "WGPU backend execution or surfaces",
        "material/SDF/UI/scene/editor adapters",
        "general serialization framework",
        "compatibility macros emitting engine paths",
        "external repository creation",
    ],
    public_api_surface: [
        "Neutral GPU parameter traits expose validated raw layout/data required by renderer plans/backends.",
        "GpuUniform and GpuStorage derives or reviewed replacements target the neutral renderer package.",
        "Generated code supports dependency renaming and contains no Runenwerk path.",
        "Unsupported types/layouts fail with precise compile diagnostics.",
    ],
    invariants: [
        "Generated byte layout matches accepted WGSL/WGPU alignment and size rules.",
        "Bytemuck traits are generated only when representation is valid for them.",
        "Padding bytes are deterministic and initialized.",
        "Nested structs, arrays, vectors, matrices, and alignment are either correctly supported or explicitly rejected.",
        "Macros preserve supported generics/where clauses and visibility.",
        "No hidden backend/device/global state participates in conversion.",
    ],
    acceptance_criteria: [
        "External package derives accepted uniform/storage forms through renamed dependencies.",
        "Compile-fail fixtures reject unsupported fields/layouts with stable diagnostic anchors.",
        "ABI fixtures compare Rust layout/bytes with independently defined WGSL/WGPU expectations.",
        "Generated code imports only neutral renderer and approved external dependencies.",
        "Current engine parameter users migrate without compatibility macro aliases.",
        "No shader/backend/product scope enters the phase.",
    ],
    validation_commands: [
        "cargo +stable fmt --all --check",
        "focused GPU parameter/layout tests",
        "trybuild or repository-approved compile-pass/compile-fail suite",
        "cargo test -p engine_render_macros --locked when package tests exist",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine -p engine_render_macros --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide supported/rejected ABI matrix and independent expected layouts.",
        "Provide expanded/generated path evidence and dependency-renaming proof.",
        "Record all migrated derive users and removed engine-path generation.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if current macros encode product/material semantics rather than generic GPU layout.",
        "Stop if ABI correctness cannot be independently tested.",
        "Stop if R3 prepared-input types are not stable enough for the traits.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record accepted ABI surface, macro migrations, fixture results, validation, and R5 prerequisites.",
    ],
    next_phase_activation_condition: "R5 requires accepted R4 GPU parameter/macro closeout and separate implementation authorization.",
)
