PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R7",
    title: "Generic Surfaces and Device-Loss Contract",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenRender WGPU surface owner plus Runenwerk native-window host owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current surface/window coupling subject to exact local host consumer inventory",
    complete_design_gate_status: "complete for host/core/WGPU split; implementation requires R6 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: native host mapping, core surface identity/reports, WGPU surface execution",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/backend/surface.rs",
        "surface-related portions of engine/src/plugins/render/backend/wgpu_ctx.rs",
        "internal neutral core/WGPU surface modules/manifests",
        "Runenwerk native-window mapping and host integration paths discovered before activation",
        "focused surface lifecycle/multi-surface/error/device-loss tests",
        "proof and closeout docs",
    ],
    forbidden_paths: [
        "Winit dependency in target renderer packages",
        "NativeWindowId in core/WGPU public contracts",
        "general app/window/event-loop redesign",
        "product feature/material/SDF/UI/editor migration",
        "compatibility surface registry retaining mixed ECS/window/WGPU authority",
        "external repository creation",
    ],
    public_api_surface: [
        "Core owns opaque SurfaceId, desired size/presentation intent, and backend-neutral lifecycle/recovery reports.",
        "WGPU owns wgpu::Surface, capabilities, configuration, acquire, present, retirement, and backend errors.",
        "Runenwerk owns Winit/native windows, NativeWindowId, event loop, DPI/resize/visibility, and mapping to SurfaceId.",
        "WGPU accepts a generic surface target/raw-window-handle-compatible host contract without depending on Winit.",
    ],
    invariants: [
        "Underlying native window lifetime outlives every attached WGPU surface and is explicit in the host contract.",
        "Surface IDs/generations are stale-safe and renderer-local.",
        "Resize/reconfigure/acquire/present/retire ordering is deterministic and reported.",
        "Outdated, Lost, Timeout, OutOfMemory, and DeviceLost are distinct outcomes.",
        "RunenRender reports recovery requirements; Runenwerk owns retry/recreate/close/shutdown policy.",
        "Device-loss reconstruction identifies renderer resources requiring recreation without assuming ECS lifetime.",
    ],
    acceptance_criteria: [
        "Target core/WGPU code contains no Winit or NativeWindowId import.",
        "Host mapping supports at least one window and multiple renderer surfaces according to accepted policy.",
        "Surface configure/resize/acquire/present/retire tests pass where runtime environment supports them.",
        "Recoverable and terminal surface/device outcomes have focused injected or runtime proofs.",
        "Headless operation from R6 remains possible without surface code.",
        "Mixed legacy surface registry authority is removed without compatibility facade.",
    ],
    validation_commands: [
        "activation-time native-window/surface consumer inventory",
        "cargo +stable fmt --all --check",
        "focused surface mapping/lifecycle/error tests",
        "focused WGPU multi-surface/device-loss tests where environment supports",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "rg -n 'winit::|NativeWindowId' target neutral/WGPU modules",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Map every old surface/window field and method to final owner.",
        "Record OS/windowing/backend/adapter/device for runtime surface evidence.",
        "Prove structured surface/device outcomes and headless non-regression.",
        "Prove forbidden Winit/NativeWindowId dependency absence.",
        "Report unavailable runtime cases honestly.",
    ],
    stop_conditions: [
        "Stop if WGPU surface ownership cannot be separated from Winit event-loop policy.",
        "Stop if native-window lifetime cannot be expressed safely through accepted WGPU/raw-window-handle contracts.",
        "Stop if changed surface/device behavior cannot be runtime-tested.",
        "Stop if R6 backend separation is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record surface/host/backend APIs, platform evidence, recovery matrix, validation, and R8 prerequisites.",
    ],
    next_phase_activation_condition: "R8 requires accepted R7 surface/device-loss closeout and separate implementation authorization.",
)
