PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R8",
    title: "Neutralize RunenSchedule and ECS Runtime Integration",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "runen_schedule owner plus RunenECS runtime integration owner and Runenwerk lifecycle migration owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
    ],
    complete_investigation_gate_status: "complete for product vocabulary and global telemetry findings subject to exact local consumer inventory",
    complete_design_gate_status: "complete for neutral scheduler target; implementation requires R7 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: generic scheduling, ECS integration, Runenwerk lifecycle hooks",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/scheduler/**",
        "domain/ecs/src/system/runtime.rs",
        "domain/ecs/src/system/mod.rs",
        "domain/ecs/src/errors.rs only for ECS schedule integration errors",
        "domain/ecs/tests/runtime_plan*.rs",
        "domain/scheduler tests/**",
        "engine schedule/lifecycle call sites required to own removed phases/barriers",
        "focused app/plugin migration tests",
        "docs-site/src/content/docs/domain/ecs/** and scheduler/engine docs required by public API changes",
        "proof/closeout docs",
    ],
    forbidden_paths: [
        "parallel executor implementation",
        "new worker pool or global executor",
        "retaining Runenwerk phase/barrier compatibility enums",
        "render graph or renderer backend redesign",
        "network protocol, messaging, spatial, reflection, or repository extraction",
        "global telemetry/logging replacement under another name",
    ],
    public_api_surface: [
        "runen_schedule exposes context-generic labels, sets, access declarations, registered systems, deterministic DAG stages/waves, reports, and structured errors.",
        "ExecutionPhaseKind and product BarrierKind are removed.",
        "RunenECS maps systems/params to schedule access and flushes deferred commands at accepted generic stage boundaries.",
        "Runenwerk owns startup/update/fixed/render/frame-end/publication/generation/replay/network lifecycle hooks.",
        "Serial execution is the normative reference.",
    ],
    invariants: [
        "runen_schedule has no ECS or Runenwerk dependency.",
        "Schedule plan/order is deterministic for equal registrations and constraints.",
        "Cycles, duplicate labels, invalid set references, and access conflicts produce structured errors.",
        "System ID exhaustion is structured and never saturating reuse.",
        "Deferred commands flush only after successful accepted stages and never after failed systems as success.",
        "No process-global telemetry, logging flag, or hard-coded system-name exception remains.",
        "Runenwerk lifecycle behavior is preserved through host-owned hooks.",
    ],
    acceptance_criteria: [
        "No ExecutionPhaseKind or product BarrierKind remains in scheduler public API.",
        "Scheduler tests prove generic labels/sets/cycles/conflicts/stages/waves without engine.",
        "ECS runtime tests prove command barriers and failure behavior over neutral stages.",
        "Runenwerk app/render/network lifecycle tests preserve required ordering through integration-owned hooks.",
        "Public scheduler/runtime errors are structured, not anyhow strings.",
        "Global telemetry and render-submit logging exception are removed.",
        "No parallel-execution claim or worker-pool scope is introduced.",
    ],
    validation_commands: [
        "activation-time rg for ExecutionPhaseKind, BarrierKind, set_slow_node_logging_enabled, scheduler telemetry, scheduler consumers",
        "cargo +stable fmt --all --check",
        "cargo test -p scheduler --all-features --locked",
        "cargo test -p ecs --all-features --locked",
        "focused engine lifecycle/render/network ordering tests",
        "cargo clippy -p scheduler -p ecs --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Map every removed phase/barrier to its final Runenwerk lifecycle owner.",
        "Prove deterministic generic planning and ECS command flush behavior.",
        "Prove absence of globals/product vocabulary in scheduler.",
        "Report structured error migration and exact ordering tests.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if product phases/barriers cannot be removed without a broader app lifecycle design.",
        "Stop if current scheduler consumers require renderer-specific semantics inside the package.",
        "Stop if parallel execution is required to preserve current behavior.",
        "Stop if R7 separation is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record scheduler API, lifecycle migration map, deterministic proof, validation, and R9 prerequisites.",
    ],
    next_phase_activation_condition: "R9 requires accepted R8 scheduler closeout and separate implementation authorization.",
)
