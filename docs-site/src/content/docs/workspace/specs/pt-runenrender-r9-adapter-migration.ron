PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R9",
    title: "Migrate Runenwerk Render Domain and Runtime Adapters",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "Runenwerk render host and scene/material/SDF/UI/editor adapter owners",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
        "ARCHITECTURE.md",
        "DOMAIN_MAP.md",
        "DEPENDENCY_RULES.md",
    ],
    complete_investigation_gate_status: "complete for semantic owner categories subject to exact local call-site inventory",
    complete_design_gate_status: "complete for adapter target; implementation requires R8 closeout and activation with exact file map",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: Runenwerk host/plugin and domain adapters over public renderer seams",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/features/**",
        "engine/src/plugins/render/material_compiler/**",
        "engine/src/plugins/render/procedural/**",
        "engine/src/plugins/render/residency/**",
        "engine/src/plugins/render/runtime/**",
        "engine/src/plugins/render/texture_upload.rs",
        "engine/src/plugins/render/plugin.rs",
        "engine/src/plugins/render/composition/integration.rs",
        "scene/world/material/SDF/editor/UI/app call sites found by local inventory",
        "focused adapter/application tests",
        "current architecture and proof/closeout docs",
    ],
    forbidden_paths: [
        "new domain semantics in neutral core/WGPU",
        "private reach-through into renderer internal modules",
        "compatibility renderer APIs or duplicate rendering path",
        "RunenUI repository/API work",
        "RunenSDF/RunenECS extraction",
        "external RunenRender repository creation",
        "broad app/editor/product redesign unrelated to renderer adaptation",
    ],
    public_api_surface: [
        "Runenwerk RenderPlugin/host composes lifecycle and submits explicit public renderer inputs.",
        "Scene, material, SDF/world, UI, editor, debug, shader-file, texture-asset, and product policy live in Runenwerk adapters.",
        "Adapters translate to generic renderer resources/passes/producers/views/targets and preserve diagnostics.",
        "Neutral/WGPU packages expose no Runenwerk/domain private escape hatch.",
    ],
    invariants: [
        "Every product/domain feature reaches renderer through public generic contracts only.",
        "No neutral/WGPU module imports scene, material_graph, world_sdf, ui_*, editor, product, ECS, or Runenwerk runtime types.",
        "Runenwerk retains lifecycle, fixed time, startup readiness, frame pacing, filesystem/KTX2/hot reload, and product fallback policy.",
        "Adapter translation is deterministic and contains no duplicate renderer algorithm.",
        "Legacy product-specific graph/pass/feature variants and private paths are removed.",
        "Only one active render preparation/submission path remains.",
    ],
    acceptance_criteria: [
        "All current scene/world/material/SDF/UI/editor/debug/runtime producers have an explicit adapter ownership map.",
        "Material compiler and texture artifact loading remain Runenwerk-owned while emitting generic shader/pipeline/resource inputs.",
        "SDF/world residency policy remains Runenwerk-owned while generic GPU lifetime services are used publicly.",
        "UI integration compiles through generic contributions without renderer UI semantics; no RunenUI work is introduced.",
        "Runenwerk plugin/runtime uses no renderer private modules.",
        "Current applications and focused visual/headless tests preserve required behavior through one path.",
        "Temporary migration seams from R2/R3 are removed.",
    ],
    validation_commands: [
        "activation-time complete producer/call-site/import inventory",
        "cargo +stable fmt --all --check",
        "focused scene/material/SDF/UI/editor/render host adapter tests",
        "cargo test -p engine --lib --locked",
        "cargo test -p engine --tests --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative shader/headless/GPU/runtime evidence commands",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide complete domain/product producer-to-adapter map.",
        "Prove forbidden imports/private reach-through absence in neutral/WGPU boundaries.",
        "Prove one active render path and removal of temporary/legacy product variants.",
        "Record application/headless/GPU behavior with environment details.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if a domain cannot be translated without adding its semantics to renderer core.",
        "Stop if Runenwerk requires private renderer access to preserve behavior.",
        "Stop if UI work requires changing RunenUI rather than using current Runenwerk-owned translation.",
        "Stop if changed GPU behavior cannot be tested.",
        "Stop if R8 diagnostics split is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record adapter map, removed legacy seams, application/GPU evidence, validation, and R10 prerequisites.",
    ],
    next_phase_activation_condition: "R10 requires accepted R9 adapter-migration closeout and separate implementation authorization.",
)
