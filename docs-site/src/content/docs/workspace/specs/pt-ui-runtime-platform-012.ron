// Compact handoff contract for one bounded implementation phase.
// Markdown authority remains primary; this spec derives from active-work,
// roadmap, production-tracks, the accepted cutover plan, runtime architecture,
// and Phase 011 closeout truth.

PhaseImplementationSpec(
    phase_id: "PT-UI-RUNTIME-PLATFORM-012",
    title: "Runtime Counter App Product",
    lifecycle_state: "active-implementation",
    implementation_authorization_status: "active-implementation-authorized-after-activation-merge",
    owner: "app/product-owned ui_counter_runtime crate with CounterPlugin, CounterScreen, host-owned Counter mutation, generic UiPlugin publication, and RenderPlugin generic consumption",

    authority_docs: [
        "AGENTS.md",
        "ARCHITECTURE.md",
        "DOMAIN_MAP.md",
        "TESTING.md",
        "docs-site/src/content/docs/workspace/start-here.md",
        "docs-site/src/content/docs/workspace/routines/track-orchestration-routine.md",
        "docs-site/src/content/docs/workspace/routines/implementation-routine.md",
        "docs-site/src/content/docs/workspace/planning/active-work.md",
        "docs-site/src/content/docs/workspace/planning/roadmap.md",
        "docs-site/src/content/docs/workspace/planning/production-tracks.md",
        "docs-site/src/content/docs/workspace/planning/decision-register.md",
        "docs-site/src/content/docs/workspace/complete-investigation-gate.md",
        "docs-site/src/content/docs/workspace/complete-design-gate.md",
        "docs-site/src/content/docs/workspace/evidence-quality-taxonomy.md",
        "docs-site/src/content/docs/workspace/complete-merge-readiness-gate.md",
        "docs-site/src/content/docs/reports/closeouts/pt-ui-runtime-platform-011-closeout.md",
        "docs-site/src/content/docs/design/active/live-uiplugin-runtime-full-cutover-plan.md",
        "docs-site/src/content/docs/architecture/live-uiplugin-runtime-platform-architecture.md",
        "docs-site/src/content/docs/architecture/ui-framework-architecture.md",
    ],

    complete_investigation_gate_status: "complete for implementation authorization; current source inspection found no apps/ui_counter_runtime crate, inspected workspace app membership, existing app command patterns, App windowed/headless APIs, UiPlugin mount/source/action/evaluation/trace/frame-publication APIs, focused engine tests, and the proof-local ui_app_integration boundary",
    complete_design_gate_status: "complete for implementation authorization; accepted cutover plus this activation contract records owner, allowed paths, forbidden paths, validation, evidence, principle checks, module decomposition, and stop conditions",
    principle_compliance_status: "complete in active-work principle compliance matrix",
    module_decomposition_status: "complete in active-work module decomposition map",
    maintainability_review_status: "complete for activation; implementation must keep product app code, generic UiPlugin runtime fixes, assets, tests, and proof docs separated by owner",

    allowed_paths: [
        "Cargo.toml only to add apps/ui_counter_runtime as a workspace member and strictly required workspace dependency entries",
        "apps/ui_counter_runtime/Cargo.toml",
        "apps/ui_counter_runtime/src/**",
        "apps/ui_counter_runtime/tests/**",
        "assets/ui_counter_runtime/scripts/increment_reset.ron",
        "engine/src/plugins/ui/action.rs only for narrow public-path fixes required by the Counter product proof",
        "engine/src/plugins/ui/app_ext.rs only for narrow mounting ergonomics required by CounterScreen",
        "engine/src/plugins/ui/diagnostics.rs only for narrow diagnostics required by product proof",
        "engine/src/plugins/ui/events.rs only for narrow event-to-action product proof wiring",
        "engine/src/plugins/ui/host.rs only for narrow host-owned mutation proof fixes",
        "engine/src/plugins/ui/mod.rs only for exports required by the product crate",
        "engine/src/plugins/ui/plugin.rs only for scheduling/resource wiring required by product proof",
        "engine/src/plugins/ui/render_publish.rs only for narrow publication evidence fixes, not render ownership changes",
        "engine/src/plugins/ui/report.rs only for narrow report accessors needed by JSONL/proof output",
        "engine/src/plugins/ui/resources.rs only for mounted source/evaluation/trace product wiring",
        "engine/src/plugins/ui/schedule.rs only for a named UiRuntimeSet if needed by product systems",
        "engine/src/plugins/ui/screen.rs only for narrow typed screen contract fixes",
        "engine/src/plugins/ui/source.rs only for narrow typed source/evaluation contract fixes",
        "engine/src/plugins/ui/trace.rs only for generic UI runtime trace JSONL/proof accessors",
        "engine/tests/ui_counter_runtime_product.rs or similarly named focused engine test only if an engine UI public-path gap cannot be proven in the app crate",
        "docs-site/src/content/docs/reports/proofs/pt-ui-runtime-platform-012-*.md only if the implementation PR records durable proof artifacts in docs",
    ],

    forbidden_paths: [
        "domain/ui/ui_app_integration/** changes",
        "ui_app_integration runtime dependency from apps/ui_counter_runtime",
        "engine/src/runtime/**",
        "engine/src/plugins/input/**",
        "apps/runenwerk_editor/**",
        "apps/runenwerk_draw/**",
        "apps/runenwerk_runtime_preview/**",
        "engine/src/plugins/render/runtime/frame_prepare.rs",
        "engine/src/plugins/render/runtime/frame_submit.rs",
        "engine/src/plugins/render/renderer/**",
        "engine/src/plugins/render/graph/**",
        "engine/src/plugins/render/backend/**",
        "engine/src/plugins/render/shader/**",
        "source reload/persistence implementation",
        "SDF or SpatialCanvas implementation",
        "domain/ui/ui_render_data/** broad primitive/model rewrites",
        "foundation/meta/**",
        "domain/app_program/**",
        "tools/docs/**",
    ],

    public_api_surface: [
        "Normal app authors compose App plus RenderPlugin, UiPlugin, and CounterPlugin.",
        "CounterPlugin uses app.mount_ui(CounterScreen).",
        "CounterScreen implements UiScreen and IntoUi through the existing typed source contract.",
        "Counter actions use UiAction and UiActionHandler with host-owned mutation.",
        "No normal app-author API may require route maps, event packets, host adapters, render registries, or manual surface-frame submission.",
        "No public manual add_ui_* registration chain.",
    ],

    invariants: [
        "App/host owns Counter { value: i64 } and all mutations.",
        "Human interaction and agent scripts use the same route, capability, payload, and host dispatch checks.",
        "Agent scripts cannot mutate Counter directly.",
        "UiPlugin owns generic mount/source/action/evaluation/trace/frame-publication infrastructure.",
        "RenderPlugin consumes only generic producer/surface/frame prepared payloads and does not own UI source/action/host semantics.",
        "ui_app_integration remains proof-local and does not become product runtime owner.",
        "No Phase 013 or Phase 014 implementation enters this phase.",
    ],

    acceptance_criteria: [
        "cargo run -p ui_counter_runtime starts the human app with title Runenwerk UI Counter Runtime.",
        "cargo run -p ui_counter_runtime -- --headless --agent-script <script> --trace-jsonl <path> --exit-after-script runs agent mode.",
        "cargo test -p ui_counter_runtime proves the app path.",
        "The app installs RenderPlugin, UiPlugin, and CounterPlugin.",
        "CounterPlugin uses app.mount_ui(CounterScreen).",
        "CounterScreen implements the accepted typed screen/source/action model and architecture-owned product screen contract.",
        "The UI exposes increment, decrement, and reset actions plus count, trace console, and status facts.",
        "Human interaction and agent scripts use the same route/capability/payload/host checks.",
        "User/agent interaction mutates Counter only through the host-owned path.",
        "Runtime/evaluator output changes after accepted mutation.",
        "UiPlugin publishes through the generic producer/surface-frame seam.",
        "RenderPlugin consumes the submission without UI semantic ownership.",
        "JSONL trace records action, mutation, evaluation, and frame publication facts.",
        "Manual run instructions and observed behavior are recorded in the PR.",
    ],

    validation_commands: [
        "cargo fmt --check",
        "cargo run -p ui_counter_runtime",
        "cargo run -p ui_counter_runtime -- --headless --agent-script <script> --trace-jsonl <path> --exit-after-script",
        "cargo test -p ui_counter_runtime",
        "focused engine tests required by any touched engine UI path",
        "cargo test --workspace if the app product proof touches cross-crate workspace behavior",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report current source inspection for app crate, workspace member, App APIs, UiPlugin public APIs, focused engine tests, and ui_app_integration boundary.",
        "Report human command output and observed behavior for cargo run -p ui_counter_runtime.",
        "Report agent command output and JSONL trace artifact facts for the increment/reset script.",
        "Report focused app crate tests and any focused engine tests for touched engine UI paths.",
        "Report proof that app authors use RenderPlugin, UiPlugin, CounterPlugin, and app.mount_ui(CounterScreen) without route maps, event packets, host adapters, or render registries.",
        "Classify evidence using E3, E5, E6 where available, E8 authority, and E9 when source/test/runtime proof and authority align.",
        "Report any skipped command with exact reason.",
    ],

    stop_conditions: [
        "Stop if the product cannot launch by command.",
        "Stop if implementation needs engine/src/runtime/** or engine/src/plugins/input/**.",
        "Stop if render backend, graph, shader, source reload, persistence, SDF, SpatialCanvas, generic framework, phase spec validator, or docs validator work is needed.",
        "Stop if ui_app_integration becomes the product runtime owner or a runtime dependency.",
        "Stop if human and agent paths use different route/capability/payload/host checks.",
        "Stop if agent mode mutates Counter directly.",
        "Stop if normal app authors must see route maps, event packets, host adapters, render registries, or manual surface-frame submissions.",
        "Stop if source/program/runtime/action/mutation/render facts cannot be proven.",
        "Stop if validation cannot be reported honestly.",
    ],

    closeout_expectations: [
        "Record delivered contract, changed files, exact modules/functions, evidence classes, validation, forbidden-scope proof, known gaps, merge readiness, and next action.",
        "Update planning/completed-work/decision-register/closeout truth before Phase 013 implementation starts.",
        "Open Phase 013 active planning only after Phase 012 is reviewed, merged, and truthfully closed.",
    ],

    next_phase_activation_condition: "PT-UI-RUNTIME-PLATFORM-013 may enter active planning only after Phase 012 implementation is reviewed, merged, and completion truth is recorded; active implementation still requires separate authorization.",
)
