PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R5",
    title: "Remove ECS Spatial and Geometry Ownership",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS core owner plus one activation-selected Runenwerk spatial integration owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
        "DOMAIN_MAP.md",
        "DEPENDENCY_RULES.md",
    ],
    complete_investigation_gate_status: "complete for duplicate ownership decision; exact consumers/adapter path require local inventory",
    complete_design_gate_status: "complete for removal target; implementation requires R4 closeout and activation-selected adapter path",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: ECS spatial deletion plus one Runenwerk adapter",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/Cargo.toml",
        "domain/ecs/src/indexing/**",
        "domain/ecs/src/world/** only spatial-index fields/hooks",
        "domain/ecs/src/lib.rs only for spatial export removal",
        "domain/ecs/tests/indexing*.rs",
        "domain/ecs/tests/spatial*.rs",
        "one existing Runenwerk spatial/world/engine integration path selected and named before activation",
        "focused adapter and despawn/update tests",
        "Cargo.lock only for geometry dependency removal",
        "current ECS/spatial architecture docs and proof/closeout docs",
    ],
    forbidden_paths: [
        "new RunenSpatial repository or generic spatial framework",
        "moving geometry into RunenECS",
        "universal geometry/core crate",
        "retaining ECS SpatialIndex/SpatialHashIndex compatibility APIs",
        "query/reflection/messaging/ownership/scheduler/network/render redesign",
        "external repository extraction",
    ],
    public_api_surface: [
        "RunenECS no longer exports spatial index types or geometry-aware world methods.",
        "Geometry-bearing components remain ordinary downstream component types.",
        "Runenwerk adapter observes entity/component changes and updates the accepted spatial implementation.",
        "The adapter API is explicit and contains no duplicated spatial algorithm.",
    ],
    invariants: [
        "runenecs has no geometry dependency.",
        "Entity despawn cannot leave stale entries in the Runenwerk spatial index.",
        "Entity/component updates produce deterministic adapter updates.",
        "Spatial query semantics remain owned by the existing spatial/spatial_index domain.",
        "No duplicate writable spatial authority remains.",
        "ECS core remains useful without any spatial adapter.",
    ],
    acceptance_criteria: [
        "geometry is removed from domain/ecs/Cargo.toml and cargo tree.",
        "ECS indexing/spatial exports and world storage/hooks are deleted.",
        "All current consumers migrate to one named Runenwerk adapter or existing spatial owner.",
        "Spawn/update/remove/despawn integration tests prove spatial consistency.",
        "Standalone ECS tests contain no geometry/spatial dependency.",
        "No new framework crate or compatibility API is introduced.",
    ],
    validation_commands: [
        "activation-time local consumer search for SpatialIndex, SpatialHashIndex, SpatialHashConfig, geometry::Aabb3, and ECS spatial methods",
        "cargo +stable fmt --all --check",
        "cargo tree -p ecs",
        "cargo test -p ecs --all-features --locked",
        "focused Runenwerk spatial adapter tests",
        "cargo clippy -p ecs --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Name the exact final Runenwerk adapter/owner before implementation.",
        "List every removed ECS spatial API and migrated consumer.",
        "Prove update/despawn consistency and ECS independence.",
        "Show cargo-tree absence of geometry from ECS.",
        "Report validation honestly.",
    ],
    stop_conditions: [
        "Stop if no existing Runenwerk owner can accept the adapter without new architecture.",
        "Stop if spatial semantics are required by core query/storage correctness rather than integration.",
        "Stop if R4 reflection work is incomplete.",
        "Stop if implementation requires a new external spatial repository.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record deleted APIs/files, adapter ownership, consumer migration, validation, and R6 prerequisites.",
    ],
    next_phase_activation_condition: "R6 requires accepted R5 spatial/geometry closeout and separate implementation authorization.",
)
