// Active implementation contract for PT-RUNENSDF-002.
// Markdown architecture, investigation, design, and planning authority remain primary.

PhaseImplementationSpec(
    phase_id: "PT-RUNENSDF-002",
    title: "RunenSDF Boundary Correction",
    lifecycle_state: "active-implementation",
    implementation_authorization_status: "authorized by repository owner on 2026-07-19; manual/local activation validation explicitly waived; skipped commands remain unexecuted evidence",
    owner: "SDF domain owner; Runenwerk integration owner only for explicit conversion and discovered-consumer migration",

    authority_docs: [
        "ARCHITECTURE.md",
        "DEPENDENCY_RULES.md",
        "DOMAIN_MAP.md",
        "docs-site/src/content/docs/architecture/repository-family-architecture.md",
        "docs-site/src/content/docs/adr/accepted/0014-repository-family-extraction-boundaries.md",
        "docs-site/src/content/docs/reports/investigations/runensdf-extraction-investigation.md",
        "docs-site/src/content/docs/design/active/runensdf-extraction-design.md",
        "docs-site/src/content/docs/workspace/planning/active-work.md",
        "docs-site/src/content/docs/workspace/planning/roadmap.md",
        "docs-site/src/content/docs/workspace/complete-investigation-gate.md",
        "docs-site/src/content/docs/workspace/complete-design-gate.md",
        "docs-site/src/content/docs/guidelines/programming-principles.md",
    ],

    complete_investigation_gate_status: "connector inspection covers all current domain/sdf source modules and all nine package test files; repository-wide Cargo/search verification was waived for activation and remains unavailable evidence",
    complete_design_gate_status: "complete for signed-value/safe-step, exact-distance capability, bounds, query terminal, validation, ownership, and phase boundaries",
    principle_compliance_status: "complete in RunenSDF extraction design",
    module_decomposition_status: "complete: one initial runensdf package; Runenwerk conversions remain external",
    maintainability_review_status: "complete for target; implementation keeps field values, errors, bounds/rays, primitives, composition, transforms, differential queries, terminal outcomes, and package tests separately owned",

    allowed_paths: [
        "domain/sdf/Cargo.toml",
        "domain/sdf/src/**",
        "domain/sdf/tests/**",
        "one existing or newly selected Runenwerk-owned geometry conversion adapter path only when a direct consumer is proven",
        "focused tests and mechanical migrations for directly discovered consumers",
        "Cargo.lock only if removing geometry or adding an accepted error dependency changes it",
        "docs-site/src/content/docs/domain/sdf/** required to align corrected current API truth",
        "docs-site/src/content/docs/reports/proofs/pt-runensdf-002-*.md",
        "docs-site/src/content/docs/reports/closeouts/pt-runensdf-002-closeout.md only after implementation review",
        "docs-site/src/content/docs/workspace/planning/active-work.md",
        "docs-site/src/content/docs/workspace/specs/pt-runensdf-002-boundary-correction.ron",
    ],

    forbidden_paths: [
        "external RunenSDF repository creation or dependency introduction",
        "deleting domain/sdf",
        "compatibility package, forwarding module, deprecated parallel SDF API, or source mirror",
        "broad engine renderer, world_sdf, procgen, material_graph, ECS, scheduler, UI, or RunenUI redesign",
        "foundation/meta or any universal geometry/core repository",
        ".github/**",
        "tools/**",
        "stable serialization format",
        "GPU, shader, material-channel, graph, renderer, or product feature expansion",
        "RunenECS or RunenRender Rust implementation",
    ],

    public_api_surface: [
        "SdfField3 remains host-neutral and returns Result<SdfSample, SampleError>, conservative FieldBounds, and explicit field capabilities.",
        "SdfSample exposes finite signed_value and optional finite non-negative safe_step through read-only accessors.",
        "safe_step is a proven lower bound to the nearest zero set; sphere tracing never substitutes abs(signed_value) when safe_step is absent.",
        "Exact-distance capability is explicit and required by projection, closest-point, and sphere-sweep queries that interpret value magnitude metrically.",
        "SDF-local validated Bounds3, FieldBounds::{Unbounded, Empty, Bounded}, and Ray3 replace Runenwerk geometry types.",
        "Primitive, composition, transform, ray, bounds, and settings fields are private where mutation would bypass invariants.",
        "Policy-heavy queries use validated settings values.",
        "Queries return explicit Hit or Miss(terminal reason) and structured invalid/evaluation/gradient/unsupported-capability errors.",
        "Helpers accept SdfField3 + ?Sized where sizing is unnecessary.",
        "No compatibility aliases or deprecated parallel APIs.",
    ],

    invariants: [
        "All public authored scalar/vector/transform/settings inputs are finite and validated.",
        "SdfSample signed_value is finite and preserves negative-inside, zero-surface, positive-outside semantics.",
        "SdfSample safe_step is absent or a finite non-negative conservative lower bound to the zero set.",
        "Sphere tracing advances only by safe_step and reports UnsupportedCapability when it is absent.",
        "Metric projection and sweep execute only for fields declaring exact-distance capability.",
        "Built-in compositions document and test safe-step and exactness propagation; otherwise they remove the capability.",
        "Bounds3 min is component-wise less than or equal to max.",
        "Disjoint finite intersection is Empty, never the operands' union.",
        "Finite bounds are conservative for every built-in value that claims them.",
        "Ray direction is finite, normalized, and non-zero; hit distance is world-space distance.",
        "Zero/singular/non-finite transforms and invalid settings are rejected rather than silently normalized.",
        "Primary normal estimation never silently substitutes Vec3::Y.",
        "Query errors, ordinary misses, bounds exits, distance limits, insufficient progress, and budget exhaustion remain distinguishable.",
        "The package has no Runenwerk geometry, ECS, renderer, world, material, or UI dependency after this phase.",
        "Runenwerk conversions live outside the SDF package and contain no SDF algorithms.",
    ],

    acceptance_criteria: [
        "domain/sdf/Cargo.toml no longer depends on geometry.",
        "All current primitives, operations, compositions, transforms, and queries migrate to invariant-preserving APIs.",
        "Exact primitives prove exact distance and safe_step = abs(signed_value) within documented tolerance.",
        "Affine, warp, smooth, repeat, mirror, clamp, and other wrappers prove conservative capability propagation or explicitly remove the unsupported capability.",
        "Tests-as-written cover no-overshoot behavior for tracing-capable built-in fields.",
        "Sign-only downstream fields remain classifiable but are rejected by capability-sensitive queries.",
        "FieldBounds algebra includes tested Empty behavior and conservative containment.",
        "Invalid NaN/infinite/negative/zero/singular inputs have deterministic negative tests.",
        "Query tests distinguish invalid input, invalid evaluation, unusable gradient, unsupported capability, ordinary miss, bounds exit, distance limit, insufficient progress, budget exhaustion, and success.",
        "A downstream-style test implementation uses SdfField3 through public APIs only.",
        "Trait-object or ?Sized query use is proven where accepted.",
        "Every direct consumer found through connector inspection migrates through the corrected API without a compatibility layer.",
        "No external repository, source deletion, renderer/world/material/UI expansion, serialization, or compatibility scope enters the diff.",
    ],

    validation_commands: [
        "git status --short --branch",
        "git rev-parse HEAD",
        "cargo metadata --format-version 1 --locked",
        "cargo tree -p sdf",
        "cargo tree -i sdf --workspace",
        "rg -n '\\bsdf\\b|SdfField3|SdfSample|FieldBounds|SdfSphere|raymarch_first_hit' .",
        "rg -n 'sdf\\s*=|package\\s*=\\s*\"sdf\"' --glob Cargo.toml .",
        "cargo +stable fmt --all --check",
        "cargo test -p sdf --locked",
        "cargo clippy -p sdf --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV test command",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report connector-inspected consumer evidence and every unavailable repository-wide search honestly.",
        "Map every changed public API item from old to new form.",
        "Report every built-in signed-value, safe-step, exactness, and bounds rule with tests-as-written.",
        "Report no-overshoot tests for tracing-capable fields and unsupported-capability tests for sign-only fields.",
        "Report every query error and terminal outcome separately.",
        "Report downstream-style public-consumer and trait-object proof as source/test evidence unless executed validation later becomes available.",
        "Report the exact Runenwerk adapter path only if a direct external consumer is proven.",
        "Report all Cargo, stable, MSRV, workspace, docs, benchmark, and diff commands as not executed unless actual output is available.",
        "Never infer command success from source inspection or owner waiver.",
    ],

    stop_conditions: [
        "Stop if connector inspection finds an unclassified public or persisted format using current SDF types.",
        "Stop if a production consumer requires material/channel payloads in SdfSample.",
        "Stop if CPU and shader source share direct source authority.",
        "Stop if a built-in composition cannot define correct sign or conservative capability behavior without an additional accepted design.",
        "Stop if singular-transform fallback is intentional product behavior.",
        "Stop if geometry removal requires a universal shared-core repository.",
        "Stop if implementation needs external repository creation, source deletion, compatibility packages, or non-SDF domain redesign.",
    ],

    closeout_expectations: [
        "Record delivered API, exact files/modules/types/functions, migrations, tests-as-written, unexecuted validation, evidence classes, principle review, forbidden-scope proof, known gaps, and next safe action.",
        "Do not activate external repository transfer until this phase is reviewed, merged, and closeout truth is recorded.",
        "Record whether package rename remains deferred to PT-RUNENSDF-003.",
    ],

    next_phase_activation_condition: "PT-RUNENSDF-003 may enter repository-creation planning only after PT-RUNENSDF-002 source is connector-reviewed and merged with truthful closeout evidence; external repository creation and transfer still require separate owner authorization.",
)
