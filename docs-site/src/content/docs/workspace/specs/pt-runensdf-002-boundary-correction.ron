// Planning-only handoff contract for PT-RUNENSDF-002.
// Markdown architecture, investigation, design, and planning authority remain primary.

PhaseImplementationSpec(
    phase_id: "PT-RUNENSDF-002",
    title: "RunenSDF Boundary Correction",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "SDF domain owner; Runenwerk geometry adapter owner only for explicit conversion and discovered-consumer migration",

    authority_docs: [
        "ARCHITECTURE.md",
        "DEPENDENCY_RULES.md",
        "DOMAIN_MAP.md",
        "docs-site/src/content/docs/architecture/repository-family-architecture.md",
        "docs-site/src/content/docs/adr/accepted/0014-repository-family-extraction-boundaries.md",
        "docs-site/src/content/docs/reports/investigations/runensdf-extraction-investigation.md",
        "docs-site/src/content/docs/design/active/runensdf-extraction-design.md",
        "docs-site/src/content/docs/workspace/planning/roadmap.md",
        "docs-site/src/content/docs/workspace/complete-investigation-gate.md",
        "docs-site/src/content/docs/workspace/complete-design-gate.md",
        "docs-site/src/content/docs/guidelines/programming-principles.md",
    ],

    complete_investigation_gate_status: "source/test/API inspection complete; local consumer and executable baseline verification required before activation",
    complete_design_gate_status: "complete for signed-value/safe-step, bounds, query terminal, validation, ownership, and phase boundaries; implementation remains unauthorized",
    principle_compliance_status: "complete in RunenSDF extraction design",
    module_decomposition_status: "complete: one initial runensdf package; Runenwerk geometry conversions remain external",
    maintainability_review_status: "complete for target; implementation must keep field values, bounds, primitives, composition, transforms, queries, and adapters cohesive and separately testable",

    allowed_paths: [
        "domain/sdf/Cargo.toml",
        "domain/sdf/src/**",
        "domain/sdf/tests/**",
        "one existing or newly selected Runenwerk-owned geometry conversion adapter path identified by activation-time consumer inventory",
        "focused tests for that conversion adapter and discovered consumers",
        "Cargo.lock only if removing the geometry dependency changes it",
        "docs-site/src/content/docs/domain/sdf/** required to align corrected current API truth",
        "docs-site/src/content/docs/reports/proofs/pt-runensdf-002-*.md",
        "docs-site/src/content/docs/reports/closeouts/pt-runensdf-002-closeout.md only after implementation merges",
    ],

    forbidden_paths: [
        "external RunenSDF repository creation or dependency introduction",
        "deleting domain/sdf",
        "compatibility package, forwarding module, or deprecated parallel SDF API",
        "broad engine renderer, world_sdf, procgen, material_graph, ECS, scheduler, UI, or RunenUI redesign",
        "foundation/meta or any universal geometry/core repository",
        ".github/**",
        "tools/** unless an accepted activation correction authorizes one narrow test fixture",
        "stable serialization format",
        "GPU, shader, material-channel, graph, renderer, or product feature expansion",
    ],

    public_api_surface: [
        "SdfField3 remains host-neutral and returns Result<SdfSample, SampleError> plus conservative FieldBounds.",
        "SdfSample exposes finite signed_value and optional finite non-negative safe_step through read-only accessors.",
        "safe_step is a proven lower bound to the nearest zero-set crossing; sphere tracing never substitutes abs(signed_value) when safe_step is absent.",
        "RunenSDF-local validated Bounds3, FieldBounds::{Unbounded, Empty, Bounded}, and Ray3 replace Runenwerk geometry types.",
        "Primitive, composition, transform, ray, bounds, and settings fields are private where mutation would bypass invariants.",
        "Policy-heavy queries use validated settings values.",
        "Queries return explicit Hit or Miss(terminal reason) and structured invalid/evaluation/unsupported-capability errors.",
        "Helpers accept SdfField3 + ?Sized where sizing is unnecessary.",
        "No compatibility aliases or deprecated parallel APIs.",
    ],

    invariants: [
        "All public authored scalar/vector/transform/settings inputs are finite and validated.",
        "SdfSample signed_value is finite and preserves negative-inside, zero-surface, positive-outside semantics.",
        "SdfSample safe_step is absent or a finite non-negative conservative lower bound to the zero set.",
        "Sphere tracing advances only by safe_step and reports UnsupportedCapability when it is absent.",
        "Built-in compositions document and test safe-step propagation; otherwise they return no safe step.",
        "Bounds3 min is component-wise less than or equal to max.",
        "Disjoint finite intersection is Empty, never the operands' union.",
        "Finite bounds are conservative for every built-in value that claims them.",
        "Ray direction is finite and non-zero; hit distance is world-space distance.",
        "Zero/singular/non-finite transforms and invalid settings are rejected rather than silently normalized.",
        "Primary normal estimation never silently substitutes Vec3::Y.",
        "Query errors, ordinary misses, bounds exits, distance limits, and budget exhaustion remain distinguishable.",
        "The package has no Runenwerk geometry, ECS, renderer, world, material, or UI dependency after this phase.",
        "Runenwerk conversions live outside the SDF package and contain no SDF algorithms.",
    ],

    acceptance_criteria: [
        "domain/sdf/Cargo.toml no longer depends on geometry.",
        "cargo tree -p sdf shows only accepted framework-neutral dependencies.",
        "All current primitives, operations, compositions, transforms, and queries migrate to invariant-preserving APIs.",
        "Exact primitives prove exact distance and safe_step = abs(signed_value) within documented tolerance.",
        "Affine, warp, smooth, repeat, mirror, clamp, and other wrappers prove conservative safe-step propagation or explicitly return no safe step.",
        "Property tests prove no sphere-tracing overshoot for supported built-in fields within documented numerical tolerance.",
        "Sign-only downstream fields are classifiable but rejected by sphere-tracing queries with UnsupportedCapability.",
        "FieldBounds algebra includes tested Empty behavior and conservative containment.",
        "Invalid NaN/infinite/negative/zero/singular inputs have deterministic negative tests.",
        "Query tests distinguish invalid input, invalid evaluation, unsupported capability, ordinary miss, bounds exit, distance limit, budget exhaustion, and success.",
        "An external downstream test package implements SdfField3 using public APIs only.",
        "Trait-object or ?Sized query use is proven where accepted.",
        "All consumers found by mandatory local search compile through the corrected API or an explicit Runenwerk adapter.",
        "No external repository, source deletion, renderer/world/material/UI expansion, serialization, or compatibility scope enters the diff.",
    ],

    validation_commands: [
        "git status --short --branch",
        "git rev-parse HEAD",
        "cargo metadata --format-version 1 --locked",
        "cargo tree -p sdf",
        "cargo tree -i sdf --workspace",
        "rg -n '\\bsdf\\b|SdfField3|SdfSample|FieldBounds|SdfSphere|raymarch_first_hit' .",
        "rg -n 'sdf\\s*=|package\\s*=\\s*\"sdf\"' --glob Cargo.toml .",
        "cargo +stable fmt --all --check",
        "cargo test -p sdf --locked",
        "cargo clippy -p sdf --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV test command",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report complete local consumer grep and cargo-tree results before implementation changes.",
        "Map every changed public API item from old to new form.",
        "Report every built-in signed-value, safe-step, and bounds rule with positive, negative, and property proof.",
        "Report no-overshoot evidence for tracing-capable fields and explicit unsupported evidence for sign-only fields.",
        "Report every query error and terminal outcome separately.",
        "Report downstream public-consumer and trait-object proof.",
        "Report the exact Runenwerk geometry adapter path and conversion ownership.",
        "Report stable, MSRV, workspace, docs, and diff validation separately.",
        "Classify unavailable or skipped commands honestly and do not infer success.",
    ],

    stop_conditions: [
        "Stop if local search finds an unclassified public or persisted format using current SDF types.",
        "Stop if a production consumer requires material/channel payloads in SdfSample.",
        "Stop if CPU and shader source share direct source authority.",
        "Stop if a built-in composition cannot define correct sign or conservative safe-step behavior without an additional accepted design.",
        "Stop if singular-transform fallback is intentional product behavior.",
        "Stop if current main fails for unrelated reasons.",
        "Stop if geometry removal requires a universal shared-core repository.",
        "Stop if implementation needs external repository creation, source deletion, or compatibility packages.",
        "Stop if implementation authorization remains active-planning-only.",
    ],

    closeout_expectations: [
        "Record delivered API, exact files/modules/types/functions, migrations, validation, evidence classes, principle review, forbidden-scope proof, known gaps, and next safe action.",
        "Do not activate external repository transfer until this phase is reviewed, merged, and closeout truth is recorded.",
        "Record whether package rename is deferred to PT-RUNENSDF-003 or completed without compatibility aliases.",
    ],

    next_phase_activation_condition: "PT-RUNENSDF-003 may enter repository-creation planning only after PT-RUNENSDF-002 is locally validated, reviewed, merged, and closed; repository creation and transfer still require separate authorization.",
)
