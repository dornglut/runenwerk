// Planning-only handoff contract for PT-RUNENSDF-002.
// Markdown architecture, investigation, design, and planning authority remain primary.

PhaseImplementationSpec(
    phase_id: "PT-RUNENSDF-002",
    title: "RunenSDF Boundary Correction",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "SDF domain owner; Runenwerk geometry adapter owner only for consumer conversion",

    authority_docs: [
        "ARCHITECTURE.md",
        "DEPENDENCY_RULES.md",
        "DOMAIN_MAP.md",
        "docs-site/src/content/docs/architecture/repository-family-architecture.md",
        "docs-site/src/content/docs/adr/accepted/0014-repository-family-extraction-boundaries.md",
        "docs-site/src/content/docs/reports/investigations/runensdf-complete-extraction-investigation.md",
        "docs-site/src/content/docs/design/active/runensdf-extraction-design.md",
        "docs-site/src/content/docs/workspace/planning/roadmap.md",
        "docs-site/src/content/docs/workspace/complete-investigation-gate.md",
        "docs-site/src/content/docs/workspace/complete-design-gate.md",
        "docs-site/src/content/docs/guidelines/programming-principles.md",
    ],

    complete_investigation_gate_status: "complete by source/test/API/manifest/docs inspection, subject to mandatory local consumer search and command baseline",
    complete_design_gate_status: "complete for boundary target; implementation remains unauthorized until local baseline and activation review pass",
    principle_compliance_status: "complete in RunenSDF extraction design",
    module_decomposition_status: "complete: one initial runensdf package; geometry conversion remains Runenwerk-owned",
    maintainability_review_status: "complete for target; implementation must keep validation, bounds, queries, primitives, transforms, and adapters separated by responsibility",

    allowed_paths: [
        "domain/sdf/Cargo.toml",
        "domain/sdf/src/lib.rs",
        "domain/sdf/src/bounds.rs",
        "domain/sdf/src/field.rs",
        "domain/sdf/src/sample.rs",
        "domain/sdf/src/epsilon.rs",
        "domain/sdf/src/gradient.rs",
        "domain/sdf/src/normal.rs",
        "domain/sdf/src/primitives/**",
        "domain/sdf/src/ops/**",
        "domain/sdf/src/combine/**",
        "domain/sdf/src/transform/**",
        "domain/sdf/src/queries/**",
        "domain/sdf/src/util/** only when retained as package-private implementation",
        "domain/sdf/tests/**",
        "one Runenwerk-owned geometry conversion adapter path selected by activation-time consumer inventory",
        "focused tests for that conversion adapter",
        "Cargo.lock only if removing the geometry dependency changes it",
        "docs-site/src/content/docs/domain/sdf/** required to align the corrected API",
        "docs-site/src/content/docs/reports/proofs/pt-runensdf-002-*.md",
        "docs-site/src/content/docs/reports/closeouts/pt-runensdf-002-closeout.md only after implementation merges",
    ],

    forbidden_paths: [
        "external RunenSDF repository creation or dependency introduction",
        "deleting domain/sdf",
        "compatibility package or module named sdf/runensdf",
        "engine/src/plugins/render/** except a consumer import migration explicitly discovered and authorized before implementation",
        "domain/world_sdf/** redesign",
        "domain/procgen/** redesign",
        "domain/material_graph/** redesign",
        "domain/ecs/**",
        "domain/scheduler/**",
        "engine_render_macros/**",
        "domain/ui/**",
        "RunenUI repository changes",
        "foundation/meta/** or any universal geometry/core repository",
        ".github/**",
        "tools/** unless an accepted activation correction explicitly authorizes one narrow validation fixture",
        "stable serialization format",
        "GPU, shader, material-channel, graph, or renderer feature expansion",
    ],

    public_api_surface: [
        "SdfField3 remains the small host-neutral field trait with sample and conservative bounds.",
        "SdfSample remains signed distance only.",
        "RunenSDF-local validated Bounds3 replaces geometry::Aabb3 in public API.",
        "FieldBounds has Unbounded, Empty, and Bounded(Bounds3) states.",
        "RunenSDF-local validated Ray3 replaces geometry::Ray3 in public query API.",
        "Policy-heavy queries use validated settings values.",
        "Query outcomes distinguish invalid/evaluation failure from valid no-result using structured errors and Option-like hit presence.",
        "Primitive, wrapper, transform, bounds, ray, and settings fields are private where mutation would bypass invariants.",
        "Helpers accept SdfField3 + ?Sized where sizing is unnecessary.",
        "No compatibility aliases or deprecated parallel APIs.",
    ],

    invariants: [
        "All authored/public scalar and vector inputs are finite and validated.",
        "Bounds3 min is component-wise less than or equal to max.",
        "Disjoint finite intersection is Empty, never the operands' union.",
        "Bounds remain conservative for all primitives, operations, compositions, and transforms.",
        "A finite bound is not claimed when a conservative finite proof is unavailable.",
        "Ray direction is finite and non-zero; hit distance is world-space distance.",
        "Zero/singular/non-finite transforms are rejected rather than converted to hidden fallback fields.",
        "Invalid epsilon/settings are rejected rather than silently defaulted.",
        "Primary normal estimation never silently substitutes Vec3::Y.",
        "Queries report invalid/non-finite field evaluation distinctly from valid miss/exhaustion.",
        "The package has no Runenwerk geometry, ECS, renderer, world, material, or UI dependency after this phase.",
        "Runenwerk conversions live outside the SDF package and contain no SDF algorithms.",
    ],

    acceptance_criteria: [
        "domain/sdf/Cargo.toml no longer depends on geometry.",
        "cargo tree -p sdf shows only accepted external/framework-neutral dependencies.",
        "All current primitives, operations, compositions, transforms, and queries migrate to invariant-preserving APIs.",
        "FieldBounds algebra includes tested Empty behavior and correct disjoint intersection.",
        "Every bounded primitive/operation/transform has conservative-bound tests or returns Unbounded.",
        "Invalid NaN/infinite/negative/zero/singular inputs have deterministic negative tests.",
        "Query tests distinguish invalid input, invalid evaluation, valid no-result, budget exhaustion, and success.",
        "An external downstream test package implements SdfField3 through public APIs only.",
        "Trait-object or ?Sized query use is proven.",
        "All consumers found by mandatory local search compile through the corrected API or an explicit Runenwerk adapter.",
        "No renderer, world, ECS, material, UI, serialization, or external-repository scope enters the diff.",
    ],

    validation_commands: [
        "git status --short --branch",
        "git rev-parse HEAD",
        "cargo metadata --format-version 1 --locked",
        "cargo tree -p sdf",
        "cargo tree -i sdf --workspace",
        "rg -n '\\bsdf\\b|SdfField3|SdfSample|FieldBounds|SdfSphere|raymarch_first_hit' .",
        "rg -n 'sdf\\s*=|package\\s*=\\s*\"sdf\"' --glob Cargo.toml .",
        "cargo +stable fmt --all --check",
        "cargo test -p sdf --locked",
        "cargo clippy -p sdf --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV test command",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report the complete local consumer grep and cargo-tree results before implementation changes.",
        "Map every changed public API item from old to new form.",
        "Report every bounds rule and corresponding positive/negative/property proof.",
        "Report every invalid-input/evaluation query outcome and proof.",
        "Report downstream public-consumer and trait-object proof.",
        "Report the exact Runenwerk geometry adapter path and conversion ownership.",
        "Report stable, MSRV, workspace, docs, and diff validation separately.",
        "Classify unavailable/skipped commands honestly and do not infer success.",
    ],

    stop_conditions: [
        "Stop if local search finds a persisted/public format using current SDF types.",
        "Stop if a production consumer requires material/channel payloads in SdfSample.",
        "Stop if GPU/shader source shares direct source authority with the CPU package.",
        "Stop if conservative bounds cannot be defined without changing accepted field semantics.",
        "Stop if singular-transform fallback is intentional product behavior.",
        "Stop if current main fails for unrelated reasons.",
        "Stop if geometry removal requires a universal shared-core repository.",
        "Stop if implementation needs external repository creation, source deletion, or compatibility packages.",
        "Stop if implementation authorization remains active-planning-only.",
    ],

    closeout_expectations: [
        "Record delivered API, exact files/modules/types/functions, migrations, validation, evidence classes, principle review, forbidden-scope proof, known gaps, and next safe action.",
        "Do not activate external repository transfer until this phase is reviewed, merged, and closeout truth is recorded.",
        "Record whether package rename is deferred to PT-RUNENSDF-003 or completed without compatibility aliases.",
    ],

    next_phase_activation_condition: "PT-RUNENSDF-003 may enter repository-creation planning only after PT-RUNENSDF-002 is locally validated, reviewed, merged, and closed; implementation still requires repository creation availability and separate authorization.",
)
