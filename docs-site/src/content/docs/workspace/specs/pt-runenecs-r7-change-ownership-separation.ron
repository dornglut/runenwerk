PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R7",
    title: "Change Journal and Ownership Network Separation",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS change-observation owner plus Runenwerk networking/product authority owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
    ],
    complete_investigation_gate_status: "complete for ownership split; generic journal retention requires local consumer proof",
    complete_design_gate_status: "complete for separation target; implementation requires R6 closeout and explicit keep/delete journal decision",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: ECS local change observation; Runenwerk ownership/interest/replication",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/src/world/change_tracking.rs",
        "domain/ecs/src/world/change_extraction/**",
        "domain/ecs/src/world/ownership/**",
        "domain/ecs/src/world/state.rs related fields only",
        "domain/ecs/src/errors.rs change-journal errors",
        "domain/ecs/src/lib.rs related exports",
        "domain/ecs/tests/change*.rs",
        "domain/ecs/tests/ownership*.rs",
        "net/engine_net/** only for ownership/interest/replication migration",
        "net/engine_sim/** and net/engine_history/** only for current change/replay consumers",
        "engine/src/plugins/net/** only for integration migration",
        "focused editor consumer paths only when local inventory proves direct dependency",
        "proof/closeout docs",
    ],
    forbidden_paths: [
        "new networking protocol or transport design",
        "raw Entity/ReflectTypeId persistence contract",
        "compatibility owner-routing API in ECS",
        "parallel scheduler/render/spatial/reflection redesign",
        "unbounded change history",
        "repository extraction",
    ],
    public_api_surface: [
        "RunenECS retains query-local added/changed/removed observation and local monotonic change identity.",
        "A generic bounded ChangeJournal remains only if local consumer evidence requires historical extraction.",
        "Any retained journal uses one local ChangeSequence/cursor and structured retention-loss outcomes.",
        "Owner roles, routing, resource ownership, transfer logs, interest filters, frame/tick windows, replication, and replay leave ECS.",
        "Runenwerk maps local entities/types to stable product/network identities.",
    ],
    invariants: [
        "ECS change observation contains no engine frame or simulation/network tick semantics.",
        "ECS change observation contains no ownership/interest/replication filtering.",
        "Change sequence exhaustion is structured and never saturating reuse.",
        "Journal retention is bounded and cursor-too-old is explicit if the journal is retained.",
        "Ownership/network migration preserves authority and routing behavior for current consumers.",
        "Raw Entity and registry-local type IDs are never durable network/replay identities.",
        "No duplicate ownership or change-extraction authority remains.",
    ],
    acceptance_criteria: [
        "Local inventory produces an explicit KEEP or DELETE decision for the generic historical journal.",
        "Query-local Added/Changed/removed behavior remains proven.",
        "Owner registry/routing/transfer APIs are absent from ECS public exports.",
        "All network/editor/replay consumers migrate to Runenwerk-owned contracts.",
        "Frame/tick sentinel windows and interest filters are absent from ECS.",
        "Stable NetEntityId/type mapping remains in Runenwerk networking.",
        "Focused network/replay/editor integration tests preserve behavior.",
    ],
    validation_commands: [
        "activation-time rg/cargo-tree inventory for change_extraction, ownership, OwnerId, OwnerRole, interest filters, frame/tick windows, replication consumers",
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo test -p engine_net --locked",
        "cargo test -p engine_sim --locked",
        "cargo test -p engine_replay --locked when package name resolves",
        "focused engine network/replay/editor tests",
        "cargo clippy -p ecs -p engine_net -p engine_sim --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Provide consumer-backed generic journal keep/delete decision.",
        "Map every ownership/change API to final owner or deletion.",
        "Prove bounded journal semantics if retained.",
        "Prove network/replay/editor behavior and stable identity mapping.",
        "Report validation and any skipped package-name command honestly.",
    ],
    stop_conditions: [
        "Stop if current consumers require raw Entity/type IDs as persisted compatibility without an accepted migration.",
        "Stop if generic journal ownership remains ambiguous.",
        "Stop if broad replication/network protocol redesign is required.",
        "Stop if R6 messaging migration is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record journal decision, removed/migrated ownership APIs, identity mapping, validation, and R8 prerequisites.",
    ],
    next_phase_activation_condition: "R8 requires accepted R7 separation closeout and separate implementation authorization.",
)
