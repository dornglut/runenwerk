PhaseImplementationSpec(
    phase_id: "PT-RUNENECS-R3",
    title: "Query and SystemParam Unsafe Boundary Hardening",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenECS unsafe query and system-parameter core owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenecs-extraction-boundary-design.md",
        "docs-site/src/content/docs/design/active/runenecs-boundary-repair-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenecs-complete-extraction-investigation.md",
    ],
    complete_investigation_gate_status: "complete for identified unsafe contracts subject to local unsafe inventory",
    complete_design_gate_status: "complete for initial sealed extension target; implementation requires R2 closeout and separate activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: query, SystemParam, storage bridges, and derive support",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "domain/ecs/src/query/**",
        "domain/ecs/src/system/params.rs",
        "domain/ecs/src/system/extract.rs",
        "domain/ecs/src/system/mod.rs",
        "domain/ecs/src/system/runtime.rs only for checked extraction and failure propagation",
        "domain/ecs/src/storage/** only for unsafe bridge corrections",
        "domain/ecs/src/errors.rs for query/param errors",
        "domain/ecs_macros/src/lib.rs only for SystemParam derive",
        "domain/ecs/tests/query*.rs",
        "domain/ecs/tests/system_param*.rs",
        "domain/ecs/tests/unsafe_boundary*.rs",
        "Miri/sanitizer fixtures and proof/closeout docs",
    ],
    forbidden_paths: [
        "parallel executor implementation",
        "reflection, messaging, spatial, ownership, change extraction, scheduler semantics, network, renderer, or repository extraction",
        "public arbitrary custom QueryData implementation in the initial release",
        "unsafe compatibility bridge exposed as ordinary safe API",
        "widening production APIs only for tests",
    ],
    public_api_surface: [
        "Public consumers compose supported built-in query forms and filters.",
        "Low-level QueryData implementation is sealed/internal for the initial release.",
        "SystemParam remains extensible through the supported derive path.",
        "The low-level SystemParam extraction bridge is sealed/doc-hidden or explicitly unsafe with a complete contract.",
        "Safe APIs return structured access/extraction errors where failure is recoverable.",
    ],
    invariants: [
        "Safe query methods do not trust arbitrary external access declarations.",
        "Duplicate mutable access to one component/resource is rejected before fetch.",
        "Raw world/storage pointers do not outlive one invocation.",
        "Query state is compatible with the intended world identity and storage generation.",
        "Derived SystemParam access declarations exactly match extracted borrows.",
        "Failed extraction publishes no commands or mutation as success.",
        "Every unsafe block and unsafe trait bridge has a complete safety explanation.",
    ],
    acceptance_criteria: [
        "External safe code cannot implement the raw QueryData contract.",
        "Supported query tuples/optional/filter/change forms remain usable.",
        "SystemParam derive works from an external package without private Runenwerk paths.",
        "Aliasing and lifetime misuse cases are rejected or proven impossible.",
        "Miri or the accepted sanitizer suite passes focused unsafe-boundary tests.",
        "Serial runtime behavior remains equivalent for valid systems.",
        "No parallel scheduling claim enters the phase.",
    ],
    validation_commands: [
        "mandatory local unsafe trait/block inventory",
        "cargo +stable fmt --all --check",
        "cargo test -p ecs --all-features --locked",
        "cargo test -p ecs_macros --locked when supported",
        "cargo clippy -p ecs -p ecs_macros --all-targets --all-features --locked -- -D warnings",
        "repository-authoritative Miri or sanitizer commands",
        "repository-authoritative MSRV tests",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "List every unsafe trait/block touched and its safety invariant.",
        "Show public compile-fail proof for sealed QueryData/manual unsafe-param paths.",
        "Show external SystemParam derive conformance.",
        "Report Miri/sanitizer environment and results.",
        "Report unchanged serial behavior and validation honestly.",
    ],
    stop_conditions: [
        "Stop if soundness requires redesigning storage beyond the bounded bridge.",
        "Stop if external arbitrary QueryData is required by a current product consumer.",
        "Stop if Miri/sanitizer evidence cannot be established before merge.",
        "Stop if R2 atomicity is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record unsafe contract inventory, conformance, Miri/sanitizer evidence, API changes, validation, and R4 prerequisites.",
    ],
    next_phase_activation_condition: "R4 requires accepted R3 unsafe-boundary closeout and separate implementation authorization.",
)
