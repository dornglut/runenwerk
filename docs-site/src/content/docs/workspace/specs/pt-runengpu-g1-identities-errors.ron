// Planning-only handoff contract for the first RunenGPU internal repair.
// Markdown architecture, investigation, and execution-plan authority remain primary.
// Implementation remains blocked until the S0 local inventory and a separate
// activation decision update this specification against current main.

PhaseImplementationSpec(
    phase_id: "PT-RUNENGPU-G1",
    title: "GPU Identities, Structured Errors, and Dependency Guards",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "GPU platform owner",

    authority_docs: [
        "ARCHITECTURE.md",
        "DEPENDENCY_RULES.md",
        "DOMAIN_MAP.md",
        "docs-site/src/content/docs/architecture/repository-family-architecture.md",
        "docs-site/src/content/docs/adr/accepted/0014-repository-family-extraction-boundaries.md",
        "docs-site/src/content/docs/adr/accepted/0015-separate-gpu-execution-from-rendering.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-extraction-investigation.md",
        "docs-site/src/content/docs/design/active/runengpu-architecture-design.md",
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/workspace/complete-investigation-gate.md",
        "docs-site/src/content/docs/workspace/complete-design-gate.md",
        "docs-site/src/content/docs/guidelines/programming-principles.md",
    ],

    complete_investigation_gate_status: "connector-backed module-family and targeted control-flow investigation recorded; local complete file, consumer, command, shader, GPU, surface, and benchmark baseline required before activation",
    complete_design_gate_status: "decision-complete for RunenGPU ownership and G1 invariants; exact current file/consumer migration remains activation-time input",
    principle_compliance_status: "complete for target design; implementation remains unauthorized",
    module_decomposition_status: "G1 only: GPU-owned identities, explicit allocators, structured identity errors, direct classified consumers, and dependency guards",
    maintainability_review_status: "G1 must not absorb resources, work graphs, shader ABI, WGPU execution, surfaces, renderer semantic identities, domain producers, or external extraction",

    allowed_paths: [
        "one new internally owned RunenGPU identity/error module at an activation-approved path",
        "engine/src/plugins/render/api/ids.rs only for mechanical removal or migration of IDs proven GPU-owned",
        "engine/src/plugins/render/backend/surface.rs only for identity references proven GPU-owned; no surface behavior redesign",
        "engine/src/plugins/render/backend/resource_allocator.rs only for mechanical identity/error migration; no resource behavior redesign",
        "engine/src/plugins/render/api/mod.rs and engine/src/plugins/render/mod.rs only for reviewed exports",
        "focused RunenGPU identity/allocation/error/dependency-guard tests",
        "current direct consumers identified by the mandatory activation-time inventory only for mechanical migration",
        "Cargo manifests only if an exact internal package/module boundary is accepted during activation; Cargo.lock changes must be mechanically bounded",
        "docs-site/src/content/docs/reports/proofs/pt-runengpu-g1-*.md",
        "docs-site/src/content/docs/reports/closeouts/pt-runengpu-g1-closeout.md only after implementation merges",
    ],

    forbidden_paths: [
        "GPU resource descriptor or lifetime redesign",
        "GPU work graph/pass/resource semantic redesign",
        "shader, pipeline, uniform/storage ABI, or macro migration",
        "WGPU instance/adapter/device/queue/resource movement",
        "surface/window/device-loss behavior redesign",
        "RunenRender scene/view/provider/material/emitter/transport identities",
        "prepared render scene or producer contribution implementation",
        "SDF, UI, material, world, scene, editor, procedural, simulation, or product migration",
        "external RunenGPU or RunenRender source creation/transfer",
        "compatibility ID wrappers, forwarding modules, duplicate allocators, or deprecated parallel APIs",
        "foundation/id or foundation/id_macros redesign",
        ".github/**",
        "tools/**",
    ],

    public_api_surface: [
        "Only runtime concepts proven to be GPU-owned receive Gpu* identities in G1.",
        "Candidate families are GpuContextId, GpuWorkId, GpuResourceId, GpuShaderId, GpuPipelineId, GpuSubmissionId, GpuReadbackId, and GpuSurfaceId; activation may remove candidates not required by current consumers.",
        "Renderer semantic identities such as views, providers, materials, emitters, contributions, and logical targets are explicitly excluded.",
        "GPU runtime identities are opaque, context-scoped where applicable, and cannot be safely reconstructed from arbitrary integers.",
        "Read-only raw values may exist for diagnostics, ordering, hashing, and trace correlation without persistence, replay, cache-format, or network-stability guarantees.",
        "Each identity family has an explicit owner-scoped allocator; allocation is fallible and never wraps, saturates into reuse, or panics through the public fallible path.",
        "Structured GpuIdentityError or equivalent distinguishes invalid/reserved input, exhaustion, stale generation, and foreign context where those states apply.",
    ],

    invariants: [
        "Every migrated identity is proven GPU-owned by the S0 inventory.",
        "GPU runtime identities and renderer semantic identities remain separate.",
        "Stable authored, persisted, shader-source, and cache keys remain separate concepts.",
        "No reserved sentinel is issued as valid.",
        "Allocation is deterministic for the same explicit allocator state and operation order.",
        "Exhaustion does not wrap, saturate, reuse, or panic through the public fallible path.",
        "Safe public APIs cannot forge arbitrary runtime IDs from raw integers.",
        "Foreign-context and stale-generation use is rejected where context/generation semantics exist.",
        "Distinct identity families remain type-distinct.",
        "Diagnostic raw values do not become stable formats.",
        "The G1 identity/error layer imports no ECS, WGPU, Winit, Runenwerk runtime, renderer semantics, SDF, UI, scene, material, editor, simulation, or product type.",
        "G1 changes no resource, graph, shader, WGPU, surface, renderer, or product behavior.",
    ],

    acceptance_criteria: [
        "The complete S0 source, identity, allocator, raw-construction, persistence, and consumer inventory is recorded before implementation starts.",
        "Every current Render* identity is classified as GPU-owned, renderer-owned, Runenwerk-owned, retired, or blocker.",
        "Only GPU-owned families migrate during G1.",
        "The reviewed identity implementation is shared without copy-pasted divergent allocator behavior.",
        "Allocator construction and allocation expose structured fallible behavior for reserved values, exhaustion, stale use, and foreign contexts where applicable.",
        "Tests cover first allocation, deterministic order, family distinction, invalid/reserved input, exhaustion, non-wrapping behavior, stale/foreign rejection where applicable, equality/order/hash, and no public raw reconstruction path.",
        "A compile/source dependency guard proves the neutral identity/error layer has no forbidden imports.",
        "No renderer semantic identity, graph, WGPU, surface behavior, shader, macro, product, or external-repository scope enters the diff.",
        "Focused, engine, workspace, stable, MSRV, docs, and diff validation are reported separately and pass or are honestly blocked before merge readiness.",
    ],

    validation_commands: [
        "git status --short --branch",
        "git rev-parse HEAD",
        "cargo metadata --format-version 1 --locked",
        "cargo tree -p engine --edges normal,build,dev",
        "rg --files engine/src/plugins/render engine_render_macros assets/shaders engine/tests engine/examples engine/benches",
        "rg -n 'Render(Flow|Pass|Resource|Feature|FrameProducer|Surface)Id|Gpu[A-Za-z]+Id|try_from_raw|\\.raw\\(' engine apps domain net adapters --glob '*.rs'",
        "rg -n 'wgpu::|winit::|ecs::|material_graph|world_sdf|ui_|Ui|Scene|Editor' activation-approved RunenGPU identity/error paths",
        "cargo +stable fmt --all --check",
        "focused RunenGPU identity/error tests",
        "cargo test -p engine --lib --locked",
        "cargo test -p engine --tests --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV validation",
        "cargo test --workspace --locked",
        "cargo clippy --workspace --all-targets --locked -- -D warnings",
        "python tools/docs/validate_docs.py",
        "pnpm --dir docs-site build",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
        "git diff --stat main...HEAD",
    ],

    evidence_expectations: [
        "Report the complete current renderer/GPU file and consumer inventory before code changes.",
        "Report the classification and rationale for every current Render* identity.",
        "Report whether any current raw ID is persisted, transmitted, replayed, or used as a stable cache key; stop on such a use until its format owner is designed.",
        "Map every migrated old identity/allocator/raw API to the corrected GPU runtime contract.",
        "Report all direct consumer migrations and all deliberately retained renderer/Runenwerk IDs.",
        "Report allocator exhaustion/stale/foreign tests without widening production-only raw constructors.",
        "Report the exact dependency-guard mechanism and result.",
        "Report focused, engine, workspace, stable, MSRV, docs, and diff validation separately.",
        "Classify unavailable, skipped, environment-dependent, or unrelated failing commands honestly.",
    ],

    stop_conditions: [
        "Stop if the S0 complete file/consumer/command inventory has not passed.",
        "Stop if a current ID has unresolved GPU versus renderer versus Runenwerk ownership.",
        "Stop if any current runtime raw ID is intentionally persisted or transmitted as a stable format.",
        "Stop if arbitrary safe raw reconstruction is a required accepted public contract.",
        "Stop if identity ownership requires resource, graph, surface, or renderer redesign outside G1.",
        "Stop if G1 requires foundation/id or id_macros redesign.",
        "Stop if current main fails for unrelated reasons that prevent trustworthy validation.",
        "Stop if implementation authorization remains active-planning-only.",
    ],

    closeout_expectations: [
        "Record exact identity/error API changes, classifications, consumer migrations, allocator behavior, dependency guards, tests, validation, evidence classes, forbidden-scope proof, known gaps, and next safe action.",
        "Do not activate G2 until G1 is reviewed, merged, and closed against current main.",
        "Write the G2 specification only after G1 implementation facts and consumer migrations are known.",
    ],

    next_phase_activation_condition: "PT-RUNENGPU-G2 may enter planning only after G1's S0 gate, implementation, validation, review, merge, and closeout; G2 implementation requires a new specification derived from current main.",
)
