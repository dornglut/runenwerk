PhaseImplementationSpec(
    phase_id: "PT-RUNENRENDER-R6",
    title: "Headless WGPU Device Resource and Pipeline Executor",
    lifecycle_state: "active-planning",
    implementation_authorization_status: "active-planning-only",
    owner: "RunenRender WGPU backend owner",
    authority_docs: [
        "docs-site/src/content/docs/design/active/runenrender-decomposition-design.md",
        "docs-site/src/content/docs/design/active/runenrender-internal-decomposition-execution-plan.md",
        "docs-site/src/content/docs/reports/investigations/runenrender-complete-semantic-inventory.md",
    ],
    complete_investigation_gate_status: "complete for current WGPU/window coupling subject to local backend/test inventory",
    complete_design_gate_status: "complete for headless backend target; implementation requires R5 closeout and activation",
    principle_compliance_status: "complete",
    module_decomposition_status: "complete: WGPU device/resources/pipelines/execution without surfaces/windows",
    maintainability_review_status: "complete for target",
    allowed_paths: [
        "engine/src/plugins/render/backend/device.rs",
        "engine/src/plugins/render/backend/wgpu_ctx.rs excluding surface/window coupling",
        "engine/src/plugins/render/renderer/** only generic WGPU execution",
        "engine/src/plugins/render/pipelines/** WGPU realization/cache",
        "engine/src/plugins/render/resource/** backend realization hooks",
        "engine/src/plugins/render/shader/** WGPU module realization only",
        "internal WGPU backend modules/manifests",
        "headless/offscreen backend tests/examples and proof/closeout docs",
    ],
    forbidden_paths: [
        "Winit dependency or NativeWindowId",
        "surface creation/configuration/presentation",
        "scene/material/SDF/UI/editor/product feature preparation",
        "filesystem hot reload",
        "Runenwerk plugin lifecycle/startup/frame pacing",
        "external repository creation",
    ],
    public_api_surface: [
        "BackendConfig explicitly selects power preference, fallback policy, required/optional features, limits, memory, trace, and labels.",
        "WGPU backend can initialize without a window or surface.",
        "Backend consumes validated core plans, shader descriptors, resources, and prepared frame inputs.",
        "Backend returns structured init/resource/shader/pipeline/submission/readback reports/errors.",
    ],
    invariants: [
        "Target WGPU boundary has no Winit, ECS, Runenwerk, UI, SDF, scene, material, or editor dependency.",
        "Unsupported features/limits are rejected before resource execution.",
        "Resource/pipeline handles are generational and stale-safe.",
        "Submission ordering and in-flight retention are explicit.",
        "No product/domain semantic dispatch occurs in backend execution.",
        "Headless compute/offscreen behavior is testable independently.",
    ],
    acceptance_criteria: [
        "Adapter/device/queue initialization succeeds in a supported headless environment without Window/Surface.",
        "Configured feature/limit negotiation positive and negative tests pass.",
        "Buffer/texture upload, compute, copy, offscreen raster, and readback proofs pass where supported.",
        "Shader/pipeline/resource errors are structured and preserve context.",
        "Generic executor imports no product feature preparation types.",
        "No surface or host lifecycle code enters R6.",
    ],
    validation_commands: [
        "activation-time WGPU/backend/import inventory",
        "cargo +stable fmt --all --check",
        "focused headless WGPU backend tests",
        "focused shader/pipeline/resource tests",
        "cargo test -p engine --lib --locked",
        "cargo clippy -p engine --all-targets --locked -- -D warnings",
        "repository-authoritative MSRV tests for core/macros where WGPU MSRV platform permits",
        "cargo test --workspace --locked",
        "python tools/docs/validate_docs.py",
        "git diff --check",
        "git diff --check main...HEAD",
        "git status --short --branch",
    ],
    evidence_expectations: [
        "Record OS, adapter, backend, device, features, and limits for runtime evidence.",
        "Separate deterministic plan tests from environment-dependent WGPU tests.",
        "Provide forbidden dependency/import proof.",
        "Record resource/pipeline generation and submission/readback outcomes.",
        "Report unavailable GPU commands honestly.",
    ],
    stop_conditions: [
        "Stop if backend initialization still requires Winit or a surface.",
        "Stop if generic execution cannot be separated from product feature preparation.",
        "Stop if no supported headless/runtime environment is available for changed backend behavior.",
        "Stop if R5 shader boundary is incomplete.",
        "Stop while authorization remains active-planning-only.",
    ],
    closeout_expectations: [
        "Record backend API, platform/device evidence, errors, dependency proof, validation, and R7 prerequisites.",
    ],
    next_phase_activation_condition: "R7 requires accepted R6 headless-WGPU closeout and separate implementation authorization.",
)
