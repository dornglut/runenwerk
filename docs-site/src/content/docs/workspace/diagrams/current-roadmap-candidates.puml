@startuml
title Runenwerk Current Roadmap Candidates

top to bottom direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Monospaced

skinparam component {
  BackgroundColor<<candidate>> #FFF2CC
  BorderColor<<candidate>> #AA7700
  BackgroundColor<<context>> #EEEEEE
  BorderColor<<context>> #666666
  FontColor<<context>> #666666
}

legend right
  <b>Selectable Work</b>
  Only planning_state=current_candidate nodes may enter implementation batches.
  Context nodes are direct dependencies and are not selectable here.
endlegend

package "Immediate Dependency Context" {
  component "WR-003 Render contract follow-ups\nstate=support_only\nV4 B2" as RENDER <<context>>

  component "WR-004 UI/editor guards\nstate=support_only\nV4 B1" as UIGUARDS <<context>>

}

package "Current Implementation Candidates" {
  component "WR-018 Rendered World V1\nstate=current_candidate\nscore=3.0 V5 B2\ncall=multi-entity SDF packet\nrender/picking consistency" as RENDERWORLD <<candidate>>

  component "WR-025 UI Runtime V2 interaction formation\nstate=current_candidate\nscore=4.8 V5 B2\ncall=retained UI first\ninteraction contracts" as UIV2 <<candidate>>

}

RENDER -down-> RENDERWORLD : dependency context
UIGUARDS -down-> RENDERWORLD : dependency context
UIGUARDS -down-> UIV2 : dependency context

@enduml
