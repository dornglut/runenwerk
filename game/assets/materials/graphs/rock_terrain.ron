(
    version: 1,
    id: "rock_terrain",
    nodes: [
        (
            id: "world_pos",
            kind: WorldPos,
        ),
        (
            id: "world_normal",
            kind: WorldNormal,
        ),
        (
            id: "slope",
            kind: SlopeMask(
                normal: "world_normal",
                power: 2.8,
                invert: false,
            ),
        ),
        (
            id: "wall_noise",
            kind: TriplanarNoise(
                position: "world_pos",
                normal: "world_normal",
                scale: 0.22,
                sharpness: 5.5,
                seed: 11.0,
            ),
        ),
        (
            id: "floor_noise",
            kind: FbmNoise(
                position: "world_pos",
                scale: 0.16,
                octaves: 4,
                lacunarity: 2.1,
                gain: 0.55,
                seed: 23.0,
            ),
        ),
        (
            id: "wall_noise_gain",
            kind: ConstantScalar(value: 0.22),
        ),
        (
            id: "floor_noise_gain",
            kind: ConstantScalar(value: 0.14),
        ),
        (
            id: "wall_noise_scaled",
            kind: Multiply(
                a: "wall_noise",
                b: "wall_noise_gain",
            ),
        ),
        (
            id: "floor_noise_scaled",
            kind: Multiply(
                a: "floor_noise",
                b: "floor_noise_gain",
            ),
        ),
        (
            id: "wall_noise_vec",
            kind: ToVec3(input: "wall_noise_scaled"),
        ),
        (
            id: "floor_noise_vec",
            kind: ToVec3(input: "floor_noise_scaled"),
        ),
        (
            id: "wall_tint",
            kind: ConstantVec3(value: [0.30, 0.29, 0.27]),
        ),
        (
            id: "floor_tint",
            kind: ConstantVec3(value: [0.16, 0.18, 0.15]),
        ),
        (
            id: "wall_color",
            kind: Add(
                a: "wall_tint",
                b: "wall_noise_vec",
            ),
        ),
        (
            id: "floor_color",
            kind: Add(
                a: "floor_tint",
                b: "floor_noise_vec",
            ),
        ),
        (
            id: "base_color",
            kind: Blend(
                a: "wall_color",
                b: "floor_color",
                mask: "slope",
            ),
        ),
        (
            id: "wall_rough",
            kind: ConstantScalar(value: 0.87),
        ),
        (
            id: "floor_rough",
            kind: ConstantScalar(value: 0.62),
        ),
        (
            id: "roughness",
            kind: Blend(
                a: "wall_rough",
                b: "floor_rough",
                mask: "slope",
            ),
        ),
        (
            id: "metallic",
            kind: ConstantScalar(value: 0.02),
        ),
        (
            id: "ao",
            kind: HeightMask(
                position: "world_pos",
                min: -1.0,
                max: 6.0,
                falloff: 1.8,
            ),
        ),
        (
            id: "emissive",
            kind: ConstantVec3(value: [0.0, 0.0, 0.0]),
        ),
    ],
    outputs: (
        base_color: "base_color",
        roughness: "roughness",
        metallic: "metallic",
        normal_perturb: None,
        ao: Some("ao"),
        emissive: Some("emissive"),
    ),
)
