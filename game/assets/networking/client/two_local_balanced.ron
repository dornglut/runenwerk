(
    version: 1,
    profile_id: "two_local_balanced",
    protocol: (
        protocol_version: 1,
        game_content_version: 1,
        schema_version: 1,
    ),
    server_id: "srv-local",
    server_name: "localhost",
    server_endpoint: "127.0.0.1:7000",
    join_ticket: "local-ticket",
    cert_path: "var/dev/server-cert.der",
    cert_fingerprint_sha256: None,
    use_axiom_handoff: false,
    axiom_api_base_url: "http://api.localhost",
    axiom_lobby_id: None,
    axiom_device_id: "grotto-client-local",
    axiom_access_token: None,
    axiom_refresh_token: None,
    shader_watch: false,
    net_sync_mode: V2,
    interpolation: (
        min_delay_ms: 50.0,
        max_delay_ms: 160.0,
        small_error_distance: 0.1,
        medium_error_distance: 0.45,
        large_error_distance: 1.0,
        hard_snap_distance: 2.6,
        small_error_blend_seconds: 0.11,
        medium_error_blend_seconds: 0.055,
    ),
    diagnostics: (
        enable_periodic_log: true,
        log_interval_ticks: 15,
        hud_network_lines_enabled: true,
    ),
    hot_reload: (
        enabled: true,
        poll_interval_seconds: 0.5,
    ),
)
