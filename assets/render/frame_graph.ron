(
  passes: [
    (
      name: "mesh_overlay",
      kind: render,
      pipeline: Some("world_compose_fullscreen"),
      reads: [mesh_data],
      writes: [surface_color],
      depends_on: [],
    ),
    (
      name: "ui_composite",
      kind: render,
      reads: [ui_draw_list],
      writes: [surface_color],
      depends_on: ["mesh_overlay"],
    ),
  ],
)
